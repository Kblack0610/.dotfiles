{
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "NTFY_URL": "https://ntfy.kblab.me/agents"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Task",
      "Skill",
      "NotebookEdit",
      "mcp__context7",
      "mcp__playwright",
      "mcp__serena",
      "mcp__claude_ai_Gmail",
      "mcp__claude_ai_Google_Calendar",
      "mcp__claude_ai_Google_Drive",
      "Bash(git fetch *)",
      "mcp__claude_ai_Atlassian__searchJiraIssuesUsingJql",
      "mcp__claude_ai_Atlassian__getJiraIssue",
      "mcp__claude_ai_Atlassian__getConfluencePage",
      "mcp__atlassian__searchJiraIssuesUsingJql",
      "mcp__atlassian__getJiraIssue",
      "mcp__figma__get_screenshot",
      "mcp__figma__get_metadata",
      "mcp__chrome-devtools__list_pages"
    ],
    "deny": [
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(su)",
      "Bash(su *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf --no-preserve-root*)",
      "Bash(dd if=*)",
      "Bash(dd of=/dev/*)",
      "Bash(mkfs*)",
      "Bash(mkfs.* *)",
      "Bash(shred *)",
      "Bash(wipefs *)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(chmod -R 777 /)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R * /)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",
      "Bash(git clean -ffd*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(curl * | zsh)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(>/dev/sda*)",
      "Bash(>/dev/nvme*)",
      "Read(/etc/shadow)",
      "Read(/etc/sudoers)",
      "Read(/etc/sudoers.d/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/*.pem)",
      "Edit(/etc/shadow)",
      "Edit(/etc/sudoers)",
      "Edit(/etc/sudoers.d/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(/etc/shadow)",
      "Write(/etc/sudoers)",
      "Write(/etc/sudoers.d/**)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "model": "opus[1m]",
  "fallbackModel": [
    "claude-sonnet-4-6",
    "claude-haiku-4-5-20251001"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/large-file-warning.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.dotfiles/.config/shared-hooks/session-preflight.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-stop-checks.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "additionalDirectories": [
    "/root/.dotfiles",
    "/root/.agent",
    "/root/.claude",
    "/root/.notes",
    "/root/.lab",
    "/root/.config",
    "/mnt/c/Users/keblack",
    "/tmp"
  ]
}
