{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "Read(/root/.agent/**)",
      "Edit(/root/.agent/**)",
      "Write(/root/.agent/**)",
      "Read(/root/.claude/**)",
      "Edit(/root/.claude/**)",
      "Write(/root/.claude/**)",
      "Read(/root/.dotfiles/**)",
      "Edit(/root/.dotfiles/**)",
      "Write(/root/.dotfiles/**)",
      "Read(/root/.notes/**)",
      "Edit(/root/.notes/**)",
      "Write(/root/.notes/**)",
      "Read(/root/.lab/**)",
      "Edit(/root/.lab/**)",
      "Write(/root/.lab/**)",
      "Read(/root/.config/**)",
      "Edit(/root/.config/**)",
      "Write(/root/.config/**)",
      "Read(/mnt/c/Users/keblack/**)",
      "Edit(/mnt/c/Users/keblack/**)",
      "Write(/mnt/c/Users/keblack/**)",
      "Read(/tmp/**)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)",
      "Read(/var/log/**)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(pipx *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(make *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(go *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(k9s *)",
      "Bash(terraform *)",
      "Bash(ansible *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(fzf *)",
      "Bash(ls *)",
      "Bash(ll *)",
      "Bash(tree *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(test *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(chmod *)",
      "Bash(tar *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(unzip *)",
      "Bash(zip *)",
      "Bash(diff *)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(env)",
      "Bash(which *)",
      "Bash(command -v *)",
      "Bash(type *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(zsh *)",
      "Bash(bash *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo rm *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(dd *)",
      "Bash(mkfs *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/large-file-warning.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-pip.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.dotfiles/.config/shared-hooks/session-preflight.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-stop-checks.sh"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
