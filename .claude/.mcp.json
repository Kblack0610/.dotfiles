{
  "mcpServers": {
    "vikunja": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@democratize-technology/vikunja-mcp"
      ],
      "env": {
        "VIKUNJA_URL": "https://vikunja.kblab.me/api/v1",
        "VIKUNJA_API_TOKEN": "${VIKUNJA_MCP_TOKEN}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "env": {}
    },
    "filesystem": {
      "type": "stdio",
      "command": "/home/kblack0610/dev/home/binks-agent-orchestrator/target/release/filesystem-mcp",
      "args": [],
      "env": {
        "RUST_LOG": "info"
      }
    }
  }
}
