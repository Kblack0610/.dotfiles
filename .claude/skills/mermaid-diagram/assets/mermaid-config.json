{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica, Arial, sans-serif",
    "fontSize": "15px",
    "primaryColor": "#e8f0fe",
    "primaryTextColor": "#1a2233",
    "primaryBorderColor": "#4a72b8",
    "secondaryColor": "#f2f4f7",
    "secondaryTextColor": "#1a2233",
    "secondaryBorderColor": "#98a2b3",
    "tertiaryColor": "#fbfcfe",
    "tertiaryTextColor": "#1a2233",
    "tertiaryBorderColor": "#d0d5dd",
    "lineColor": "#667085",
    "textColor": "#1a2233",
    "clusterBkg": "#f7f9fc",
    "clusterBorder": "#c3cbd8",
    "noteBkgColor": "#fff7e0",
    "noteTextColor": "#4a3b00",
    "noteBorderColor": "#e0c65a"
  },
  "flowchart": {
    "curve": "basis",
    "htmlLabels": true,
    "nodeSpacing": 45,
    "rankSpacing": 55,
    "padding": 10,
    "useMaxWidth": true
  },
  "sequence": {
    "useMaxWidth": true,
    "boxMargin": 8,
    "mirrorActors": false,
    "messageAlign": "center"
  },
  "er": {
    "useMaxWidth": true,
    "layoutDirection": "LR"
  },
  "gantt": {
    "useMaxWidth": true,
    "barHeight": 22,
    "fontSize": 13
  }
}
