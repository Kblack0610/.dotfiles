# D2 source (the fleet-manager convention). Edit this, then `deck diagrams` or
# `deck build` re-renders pipeline.svg. Rendered with: d2 pipeline.d2 pipeline.svg
direction: right

notes: {
  label: "~/.notes/lab/decks\n(deck home, synced)"
  shape: cylinder
}

deck: {
  label: "deck CLI"
  diagrams: "deck diagrams\n.mmd/.d2 -> .svg"
  render: "marp --theme-set\nkb-* themes"
}

out: {
  label: "PDF / HTML / PPTX"
  shape: document
}

notes -> deck: "author .md +\ndiagram sources"
deck.diagrams -> deck.render: "embed SVG"
deck.render -> out: "deck build"
