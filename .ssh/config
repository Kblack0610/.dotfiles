# Mac Studio - GitHub Actions Runner
Host mac-studio
    HostName 192.168.1.4
    User kblack0610
    IdentityFile ~/.ssh/id_ed25519

# Mac Mini M1 - Home cluster node
Host m1 mac-mini
    HostName 192.168.1.7
    User kennethblack
    IdentityFile ~/.ssh/id_ed25519

# Pi3 - Standalone AdGuard Home DNS
Host pi3 pi3-adguard
    HostName pi3-adguard.local
    User kblack0610
    IdentityFile ~/.ssh/id_ed25519
    RequestTTY no

# Force a widely-compatible terminal type for remote hosts
# This prevents "open terminal failed" errors in tmux on systems
# without modern terminfo entries (like tmux-256color)
Host *
    SetEnv TERM=xterm-256color
    RequestTTY yes
