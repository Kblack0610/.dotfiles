[Unit]
Description=Sync ~/.notes through NAS Git primary and backup remote
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/.notes
EnvironmentFile=-%h/.config/notes-sync.env
ExecStart=%h/.local/src/git/git-sync-notes.sh

[Install]
WantedBy=default.target
