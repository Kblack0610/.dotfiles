<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kblack.notes-watch</string>

    <!-- launchd's WatchPaths coalesces filesystem events natively (~few seconds),
         so no extra debounce binary needed on macOS. The path is invoked when
         contents change. -->
    <key>WatchPaths</key>
    <array>
        <string>~/.notes</string>
    </array>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>~/.local/bin/notes-sync</string>
    </array>

    <key>StandardOutPath</key>
    <string>/tmp/notes-watch.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/notes-watch.err.log</string>

    <!-- Don't run more than once every 3 seconds, regardless of how chatty
         the editor is. -->
    <key>ThrottleInterval</key>
    <integer>3</integer>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
