{
  "provider": {
    "mlx-code": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX Code",
      "options": {
        "baseURL": "http://192.168.1.4:8080/v1"
      },
      "models": {
        "mlx-community/Qwen3-Coder-Next-4bit": {
          "name": "Qwen3 Coder Next 4bit"
        }
      }
    },
    "mlx-smart": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX Smart",
      "options": {
        "baseURL": "http://192.168.1.4:8081/v1"
      },
      "models": {
        "mlx-community/Qwen3-235B-A22B-4bit-DWQ": {
          "name": "Qwen3 235B A22B 4bit DWQ"
        }
      }
    },
    "mlx-reasoning": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MLX Reasoning",
      "options": {
        "baseURL": "http://192.168.1.4:8082/v1"
      },
      "models": {
        "mlx-community/DeepSeek-R1-Distill-Qwen-32B-MLX-4Bit": {
          "name": "DeepSeek R1 Distill Qwen 32B MLX 4Bit"
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://llm.home.kennethblack.me/v1",
        "apiKey": "{env:LITELLM_MASTER_KEY}"
      },
      "models": {
        "code": {
          "name": "code"
        },
        "smart": {
          "name": "smart"
        },
        "reasoning": {
          "name": "reasoning"
        }
      }
    }
  },
  "model": "mlx-code/mlx-community/Qwen3-Coder-Next-4bit",
  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "mode": "primary"
    },
    "build": {
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "mode": "primary"
    },
    "autoaccept": {
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    },
    "code-reviewer": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false
      },
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent"
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "enabled": true,
      "environment": {}
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ],
      "enabled": true,
      "environment": {}
    },
    "filesystem": {
      "type": "local",
      "command": [
        "/home/kblack0610/dev/home/binks-agent-orchestrator/target/release/filesystem-mcp"
      ],
      "enabled": true,
      "environment": {
        "RUST_LOG": "info"
      }
    },
    "github-gh": {
      "type": "local",
      "command": [
        "/home/kblack0610/dev/home/binks-agent-orchestrator/mcps/github-gh/target/release/github-gh-mcp"
      ],
      "enabled": true,
      "environment": {
        "RUST_LOG": "info"
      }
    },
    "web-search": {
      "type": "local",
      "command": [
        "/home/kblack0610/dev/home/binks-agent-orchestrator/target/release/web-search-mcp"
      ],
      "enabled": true,
      "environment": {
        "SEARXNG_URL": "http://localhost:8080",
        "RUST_LOG": "info"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "$schema": "https://opencode.ai/config.json"
}
