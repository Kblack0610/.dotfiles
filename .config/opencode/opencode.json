{
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://llm.kblab.me/v1",
        "apiKey": "{env:LITELLM_MASTER_KEY}"
      },
      "models": {
        "code (Qwen3-Coder-Next-4bit)": {
          "name": "code"
        },
        "smart (GLM-5-4bit)": {
          "name": "smart"
        },
        "fast (Qwen3-4B)": {
          "name": "fast"
        },
        "reasoning (Qwen3.6-35B-A3B-4bit)": {
          "name": "reasoning"
        },
        "reasoning-ud (Qwen3.6-35B-A3B-UD-4bit)": {
          "name": "reasoning-ud"
        }
      }
    }
  },
  "model": "litellm/code (Qwen3-Coder-Next-4bit)",
  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "mode": "primary"
    },
    "build": {
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "mode": "primary"
    },
    "autoaccept": {
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    },
    "code-reviewer": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false
      },
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent"
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "enabled": true,
      "environment": {}
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ],
      "enabled": true,
      "environment": {}
    },
    "filesystem": {
      "type": "local",
      "command": [
        "/home/kblack0610/dev/home/binks-agent-orchestrator/target/release/filesystem-mcp"
      ],
      "enabled": true,
      "environment": {
        "RUST_LOG": "info"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "$schema": "https://opencode.ai/config.json"
}
