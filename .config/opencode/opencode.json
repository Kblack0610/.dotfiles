{
  "$schema": "https://opencode.ai/config.json",
  "model": "lazer/claude-opus-4.6",
  "small_model": "lazer/minimax-m2.7",
  "enabled_providers": [
    "lazer",
    "litellm"
  ],
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "lazer": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Lazer",
      "options": {
        "baseURL": "https://proxy.lazertechnologies.com/"
      },
      "models": {
        "claude-opus-4.6": {
          "name": "Claude Opus 4.6",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "family": "claude-opus",
          "release_date": "2026-02-05",
          "cost": {
            "input": 5,
            "output": 25
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "max": {
              "reasoningEffort": "max"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            }
          }
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "family": "claude-sonnet",
          "release_date": "2026-02-17",
          "cost": {
            "input": 3,
            "output": 15
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "max": {
              "reasoningEffort": "max"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            }
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex",
          "attachment": true,
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "limit": {
            "context": 400000,
            "output": 128000,
            "input": 272000
          },
          "family": "gpt-codex",
          "release_date": "2026-02-05",
          "cost": {
            "input": 1.75,
            "output": 14
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "minimal": {
              "reasoningEffort": "minimal"
            },
            "none": {
              "reasoningEffort": "none"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "family": "gemini-pro",
          "release_date": "2026-02-19",
          "cost": {
            "input": 2,
            "output": 12
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video",
              "audio",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "off": {
              "reasoningEffort": "none"
            }
          }
        },
        "minimax-m2.7": {
          "name": "MiniMax M2.7",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 204800,
            "output": 131072
          },
          "family": "minimax",
          "release_date": "2026-03-18",
          "cost": {
            "input": 0.3,
            "output": 1.2
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "interleaved": {
            "field": "reasoning_content"
          },
          "variants": {
            "high": {
              "reasoningEffort": "high"
            },
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "none": {
              "reasoningEffort": "none"
            }
          }
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://llm.kblab.me/v1",
        "apiKey": "{env:LITELLM_MASTER_KEY}"
      },
      "models": {
        "code (Qwen3-Coder-Next-4bit)": {
          "name": "code"
        },
        "fast (Qwen3-4B)": {
          "name": "fast"
        },
        "reasoning (Qwen3.6-35B-A3B-4bit)": {
          "name": "reasoning"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "lazer/claude-opus-4.6",
      "reasoningEffort": "high",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "build": {
      "mode": "primary",
      "model": "lazer/claude-sonnet-4.6",
      "reasoningEffort": "high",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "code-reviewer": {
      "mode": "subagent",
      "model": "lazer/claude-sonnet-4.6",
      "description": "Reviews code for best practices and potential issues",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "enabled": true,
      "environment": {}
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ],
      "enabled": true,
      "environment": {
        "DISPLAY": ":0",
        "WAYLAND_DISPLAY": "wayland-0",
        "XDG_RUNTIME_DIR": "/run/user/0/"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "vikunja": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@democratize-technology/vikunja-mcp"
      ],
      "enabled": true,
      "environment": {
        "VIKUNJA_URL": "https://vikunja.kblab.me/api/v1",
        "VIKUNJA_API_TOKEN": "${VIKUNJA_MCP_TOKEN}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": [
        "/home/kblack0610/dev/home/binks-agent-orchestrator/target/release/filesystem-mcp"
      ],
      "enabled": true,
      "environment": {
        "RUST_LOG": "info"
      }
    },
    "adb": {
      "type": "local",
      "command": [
        "/home/kblack0610/dev/home/binks-agent-orchestrator/target/release/adb-mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  }
}
