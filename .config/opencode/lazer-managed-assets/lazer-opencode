usage() {
  cat <<'EOF'
Usage: lazer-opencode <command> [args]

Commands:
  models list                           Show configured Lazer models
  models add <model-id> <name>          Add a model to the Lazer provider
  models remove <model-id>              Remove a model from the Lazer provider
  auth                                  Set or update your Lazer API key
  update [--dry-run] [--auth] [--reset-defaults]
                                        Update config and managed assets safely

Examples:
  lazer-opencode models list
  lazer-opencode models add claude-sonnet-4.6 "claude-sonnet-4.6"
  lazer-opencode models remove claude-sonnet-4.6
  lazer-opencode auth
  lazer-opencode update --dry-run
EOF
  exit 1
}

require_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed."
    echo "Install it with: brew install jq (macOS) or sudo apt-get install jq (Linux)"
    exit 1
  fi
}

resolve_cli_install_file() {
  local cli_path=""

  if cli_path="$(command -v lazer-opencode 2>/dev/null)"; then
    printf '%s\n' "$cli_path"
    return
  fi

  if [[ -x "${BASH_SOURCE[0]}" ]]; then
    printf '%s\n' "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
    return
  fi

  printf '%s\n' "$CLI_INSTALL_FILE"
}

ensure_lazer_config() {
  if [[ ! -f "$OPENCODE_CONFIG_FILE" ]]; then
    echo "Error: OpenCode config not found at $OPENCODE_CONFIG_FILE"
    echo "Run the Lazer installer first: bash install.sh"
    exit 1
  fi
  if ! jq -e '.provider.lazer' "$OPENCODE_CONFIG_FILE" &>/dev/null; then
    echo "Error: Lazer provider not configured in $OPENCODE_CONFIG_FILE"
    echo "Run the Lazer installer first: bash install.sh"
    exit 1
  fi
}

read_secret() {
  local secret=""
  local char=""
  while IFS= read -rsn1 char < /dev/tty; do
    if [[ -z "$char" ]]; then
      break
    fi
    if [[ "$char" == $'\x7f' || "$char" == $'\b' ]]; then
      if [[ -n "$secret" ]]; then
        secret="${secret%?}"
        printf '\b \b' >&2
      fi
    else
      secret+="$char"
      printf '*' >&2
    fi
  done
  printf '\n' >&2
  printf '%s' "$secret"
}

verify_model() {
  local model_id="$1"
  echo ""
  echo "[..] Verifying — asking lazer/$model_id for a joke..."
  echo ""
  local joke
  joke=$(opencode run -m "lazer/$model_id" "Tell me a short joke, one-liner only. No extra commentary." 2>/dev/null | grep -v -E "^(Performing|sqlite-migration|Database migration|$)") || true

  if [[ -n "$joke" ]]; then
    echo "  $joke"
    echo ""
    echo "It works!"
  else
    echo "  (Could not reach model — check your API key with 'lazer-opencode auth')"
  fi
}

atomic_write() {
  local target="$1"
  local content="$2"
  local tmp
  tmp=$(mktemp)
  printf '%s\n' "$content" > "$tmp"
  mv "$tmp" "$target"
}

backup_file() {
  local target="$1"
  local dry_run="$2"

  if [[ -f "$target" ]]; then
    if [[ "$dry_run" == "true" ]]; then
      echo "[dry-run] Would back up $target to ${target}.bak"
    else
      cp "$target" "${target}.bak"
    fi
  fi
}

fetch_asset_to_tmp() {
  local repo_path="$1"
  local tmp_path="$2"
  local script_dir
  local managed_asset_path="${OPENCODE_MANAGED_ASSETS_DIR}/${repo_path}"
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  if [[ -f "${script_dir}/${repo_path}" ]]; then
    cp "${script_dir}/${repo_path}" "$tmp_path"
    return
  fi

  if [[ -f "$managed_asset_path" ]]; then
    cp "$managed_asset_path" "$tmp_path"
    return
  fi

  if command -v gh &>/dev/null; then
    gh api "repos/${REPO_SLUG}/contents/${repo_path}" --jq '.content' | base64 -d > "$tmp_path"
    return
  fi

  echo "Error: Cannot fetch ${repo_path}."
  echo "Install GitHub CLI (gh) or run update from a local checkout of this repo."
  exit 1
}

apply_managed_asset() {
  local repo_path="$1"
  local target_path="$2"
  local dry_run="$3"
  local needs_sudo="$4"
  local executable="${5:-false}"
  local tmp
  tmp=$(mktemp)
  fetch_asset_to_tmp "$repo_path" "$tmp"

  if [[ -f "$target_path" ]] && cmp -s "$tmp" "$target_path"; then
    echo "[ok] ${target_path} already up to date"
    rm -f "$tmp"
    return
  fi

  if [[ "$dry_run" == "true" ]]; then
    if [[ -f "$target_path" ]]; then
      echo "[dry-run] Would update ${target_path} from ${repo_path}"
    else
      echo "[dry-run] Would install ${target_path} from ${repo_path}"
    fi
    rm -f "$tmp"
    return
  fi

  backup_file "$target_path" "false"

  if [[ "$needs_sudo" == "true" ]]; then
    sudo cp "$tmp" "$target_path"
    if [[ "$executable" == "true" ]]; then
      sudo chmod 755 "$target_path"
    else
      sudo chmod 644 "$target_path"
    fi
  else
    mkdir -p "$(dirname "$target_path")"
    cp "$tmp" "$target_path"
    if [[ "$executable" == "true" ]]; then
      chmod 755 "$target_path"
    else
      chmod 644 "$target_path"
    fi
  fi

  rm -f "$tmp"
  echo "[ok] Updated ${target_path}"
}

models_list() {
  ensure_lazer_config
  echo "Lazer models:"
  echo ""
  if command -v column &>/dev/null; then
    jq -r '.provider.lazer.models | to_entries[] | "  \(.key)\t\(.value.name)"' "$OPENCODE_CONFIG_FILE" | column -t -s $'\t'
  else
    jq -r '.provider.lazer.models | to_entries[] | "  \(.key)  \(.value.name)"' "$OPENCODE_CONFIG_FILE"
  fi
}

models_add() {
  local model_id="${1:-}"
  local model_name="${2:-}"

  if [[ -z "$model_id" || -z "$model_name" ]]; then
    echo "Usage: lazer-opencode models add <model-id> <display-name>"
    echo "Example: lazer-opencode models add claude-sonnet-4.6 \"claude-sonnet-4.6\""
    exit 1
  fi

  ensure_lazer_config

  local updated
  updated=$(jq --arg id "$model_id" --arg name "$model_name" \
    '.provider.lazer.models[$id] = {"name": $name}' "$OPENCODE_CONFIG_FILE")
  atomic_write "$OPENCODE_CONFIG_FILE" "$updated"
  echo "Added model: $model_id ($model_name)"

  verify_model "$model_id"
}

models_remove() {
  local model_id="${1:-}"

  if [[ -z "$model_id" ]]; then
    echo "Usage: lazer-opencode models remove <model-id>"
    exit 1
  fi

  ensure_lazer_config

  if ! jq -e --arg id "$model_id" '.provider.lazer.models[$id]' "$OPENCODE_CONFIG_FILE" &>/dev/null; then
    echo "Error: Model '$model_id' not found in Lazer config."
    echo "Run 'lazer-opencode models list' to see available models."
    exit 1
  fi

  local updated
  updated=$(jq --arg id "$model_id" 'del(.provider.lazer.models[$id])' "$OPENCODE_CONFIG_FILE")
  atomic_write "$OPENCODE_CONFIG_FILE" "$updated"
  echo "Removed model: $model_id"
}

auth_configure() {
  echo "Enter your Lazer API key:"
  printf "> "
  local api_key
  api_key=$(read_secret)

  if [[ -z "$api_key" ]]; then
    echo "Error: API key cannot be empty."
    exit 1
  fi

  mkdir -p "$OPENCODE_DATA_DIR"

  local updated
  if [[ -f "$OPENCODE_AUTH_FILE" ]]; then
    updated=$(jq --arg key "$api_key" '.lazer = {"type": "api", "key": $key}' "$OPENCODE_AUTH_FILE")
  else
    updated=$(jq -n --arg key "$api_key" '{"lazer": {"type": "api", "key": $key}}')
  fi
  atomic_write "$OPENCODE_AUTH_FILE" "$updated"
  chmod 600 "$OPENCODE_AUTH_FILE"
  echo "Lazer API key updated."

  local test_model
  test_model=$(jq -r --arg preferred "$PREFERRED_VERIFICATION_MODEL" '.provider.lazer.models | if has($preferred) then $preferred else (keys[0] // empty) end' "$OPENCODE_CONFIG_FILE" 2>/dev/null) || true
  if [[ -n "$test_model" && "$test_model" != "null" ]]; then
    verify_model "$test_model"
  fi
}

update_config() {
  local dry_run="$1"
  local reset_defaults="$2"
  ensure_lazer_config

  local updated
  updated=$(jq \
    --argjson lazer "$LAZER_PROVIDER_JSON" \
    --argjson retired_model_ids "$RETIRED_LAZER_MODEL_IDS_JSON" \
    --arg default_model "$DEFAULT_MODEL" \
    --arg plan_model "$PLAN_MODEL" \
    --arg build_model "$BUILD_MODEL" \
    --argjson reset_defaults "$reset_defaults" \
    '.provider = (.provider // {})
    | .provider.lazer = (.provider.lazer // {})
    | .provider.lazer.npm = $lazer.npm
    | .provider.lazer.name = $lazer.name
    | .provider.lazer.options = $lazer.options
    | .provider.lazer.models = (((.provider.lazer.models // {}) | delpaths($retired_model_ids | map([.]))) + ($lazer.models // {}))
    | .agent = (.agent // {})
    | .agent.plan = (.agent.plan // {})
    | .agent.build = (.agent.build // {})
    | if $reset_defaults then
        .model = $default_model
        | .agent.plan.model = $plan_model
        | .agent.build.model = $build_model
      else
        if ((.model // "") == "") then .model = $default_model else . end
        | if ((.agent.plan.model // "") == "") then .agent.plan.model = $plan_model else . end
        | if ((.agent.build.model // "") == "") then .agent.build.model = $build_model else . end
      end' "$OPENCODE_CONFIG_FILE")

  local current_sorted
  local updated_sorted
  current_sorted=$(jq -S . "$OPENCODE_CONFIG_FILE")
  updated_sorted=$(printf '%s\n' "$updated" | jq -S .)

  if [[ "$current_sorted" == "$updated_sorted" ]]; then
    echo "[ok] OpenCode config already up to date"
    return
  fi

  if [[ "$dry_run" == "true" ]]; then
    echo "[dry-run] OpenCode config would be updated: $OPENCODE_CONFIG_FILE"
    return
  fi

  backup_file "$OPENCODE_CONFIG_FILE" "false"
  atomic_write "$OPENCODE_CONFIG_FILE" "$updated"
  echo "[ok] Updated $OPENCODE_CONFIG_FILE"
}

update_assets() {
  local dry_run="$1"
  local cli_install_file
  cli_install_file="$(resolve_cli_install_file)"

  apply_managed_asset "lazer-opencode" "$cli_install_file" "$dry_run" "false" "true"
  apply_managed_asset "opencode-expert.md" "$OPENCODE_EXPERT_AGENT_FILE" "$dry_run" "false" "false"
  apply_managed_asset "lazer-updater.md" "$OPENCODE_UPDATER_AGENT_FILE" "$dry_run" "false" "false"
  apply_managed_asset "lazer-update.md" "$OPENCODE_UPDATE_COMMAND_FILE" "$dry_run" "false" "false"
}

update_run() {
  local dry_run="false"
  local update_auth="false"
  local reset_defaults="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run="true"
        ;;
      --auth)
        update_auth="true"
        ;;
      --reset-defaults)
        reset_defaults="true"
        ;;
      *)
        echo "Error: Unknown update option '$1'"
        echo "Usage: lazer-opencode update [--dry-run] [--auth] [--reset-defaults]"
        exit 1
        ;;
    esac
    shift
  done

  update_config "$dry_run" "$reset_defaults"
  update_assets "$dry_run"

  if [[ "$update_auth" == "true" ]]; then
    if [[ "$dry_run" == "true" ]]; then
      echo "[dry-run] Would prompt to update Lazer API key"
    else
      auth_configure
    fi
  else
    echo "[ok] Auth unchanged (use --auth to update API key)"
  fi
}

# --- Command routing ---

require_jq

case "${1:-}" in
  models)
    case "${2:-}" in
      list)   models_list ;;
      add)    models_add "${3:-}" "${4:-}" ;;
      remove) models_remove "${3:-}" ;;
      *)      usage ;;
    esac
    ;;
  auth)
    auth_configure
    ;;
  update)
    shift
    update_run "$@"
    ;;
  *)
    usage
    ;;
esac
