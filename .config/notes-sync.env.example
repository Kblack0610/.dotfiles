# Optional overrides for git-sync-notes.sh

# Primary remote (Forgejo at git.example.internal by default).
NOTES_SYNC_PRIMARY_REMOTE=origin

# Backup remote (GitHub). Only the master device should have this configured;
# other devices push to origin only.
NOTES_SYNC_BACKUP_REMOTE=backup

# Mirror remote — push-only, failures are non-fatal. Used during the
# 2026-05 NAS-to-Forgejo deprecation window so the legacy NAS bare repo
# stays in sync. Leave unset (or empty) once retirement is complete.
NOTES_SYNC_MIRROR_REMOTE=nas

# Optional SSH key override (used for any SSH remotes). Forgejo over HTTPS
# does not need this; the legacy NAS remote does.
# NOTES_SYNC_SSH_KEY=$HOME/.ssh/id_notes_sync

# NOTES_SYNC_BRANCH=master
# NOTES_SYNC_STATE_DIR=$HOME/.local/state/notes-sync
