// -*- mode: jsonc -*-
// Workstation profile (no battery, no backlight, no PPD).
{
    "include": [
        "~/.config/waybar/config.base"
    ],
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/ai-agents",
        "idle_inhibitor",
        "pulseaudio",
        "custom/bluetooth",
        "network",
        "cpu",
        "memory",
        "temperature",
        "clock#date",
        "clock#time",
        "tray"
    ]
}
