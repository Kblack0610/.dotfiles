{
  logging: {
    level: "info",
    file: "~/.openclaw/logs/openclaw.log",
    consoleLevel: "info",
    consoleStyle: "pretty",
    redactSensitive: "tools",
  },

  messages: {
    ackReaction: "👀",
  },

  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      userTimezone: "America/Los_Angeles",
      model: {
        primary: "litellm/code (Qwen3-Coder-Next-4bit)",
        fallbacks: [
          "litellm/reasoning (Qwen3.6-35B-A3B-4bit)",
        ],
      },
      models: {
        "litellm/code (Qwen3-Coder-Next-4bit)": {
          alias: "code",
        },
        "litellm/reasoning (Qwen3.6-35B-A3B-4bit)": {
          alias: "reasoning",
        },
        "litellm/fast (Qwen3-4B)": {
          alias: "fast",
        },
      },
      thinkingDefault: "low",
      timeoutSeconds: 600,
      subagents: {
        maxSpawnDepth: 1,
        maxChildrenPerAgent: 4,
        maxConcurrent: 4,
        runTimeoutSeconds: 900,
        archiveAfterMinutes: 120,
      },
      sandbox: {
        mode: "off",
      },
    },
    list: [
      {
        id: "home-orchestrator",
        default: true,
        name: "Home Orchestrator",
        workspace: "~/.openclaw/workspace-home-orchestrator",
        agentDir: "~/.openclaw/agents/home-orchestrator/agent",
        model: {
          primary: "litellm/reasoning (Qwen3.6-35B-A3B-4bit)",
          fallbacks: [
            "litellm/code (Qwen3-Coder-Next-4bit)",
          ],
        },
        subagents: {
          allowAgents: ["ops-observer", "ops-escalate", "pr-coordinator"],
        },
        tools: {
          allow: [
            "read",
            "sessions_list",
            "sessions_history",
            "sessions_spawn",
            "session_status",
            "subagents",
          ],
          deny: [
            "exec",
            "process",
            "write",
            "edit",
            "apply_patch",
            "cron",
            "nodes",
          ],
        },
      },
      {
        id: "ops-observer",
        name: "Ops Observer",
        workspace: "~/.openclaw/workspace-ops-observer",
        agentDir: "~/.openclaw/agents/ops-observer/agent",
        model: {
          primary: "litellm/reasoning (Qwen3.6-35B-A3B-4bit)",
        },
        tools: {
          deny: ["write", "edit", "apply_patch", "cron", "nodes"],
        },
      },
      {
        id: "ops-escalate",
        name: "Ops Escalate",
        workspace: "~/.openclaw/workspace-ops-escalate",
        agentDir: "~/.openclaw/agents/ops-escalate/agent",
        model: {
          primary: "litellm/reasoning (Qwen3.6-35B-A3B-4bit)",
        },
        tools: {
          deny: ["write", "edit", "apply_patch"],
        },
        subagents: {
          allowAgents: [],
        },
      },
      {
        id: "pr-coordinator",
        name: "PR Coordinator",
        workspace: "~/.openclaw/workspace-pr-coordinator",
        agentDir: "~/.openclaw/agents/pr-coordinator/agent",
        model: {
          primary: "litellm/code (Qwen3-Coder-Next-4bit)",
          fallbacks: [
            "litellm/reasoning (Qwen3.6-35B-A3B-4bit)",
          ],
        },
        subagents: {
          allowAgents: [],
        },
      },
    ],
  },

  tools: {
    agentToAgent: {
      enabled: true,
      allow: ["home-orchestrator", "ops-observer", "ops-escalate", "pr-coordinator"],
    },
    sessions: {
      visibility: "all",
    },
    exec: {
      host: "gateway",
      security: "allowlist",
      ask: "on-miss",
      notifyOnExit: true,
    },
  },

  models: {
    mode: "merge",
    providers: {
      // LiteLLM gateway (mac-studio mlx-server fronted via in-cluster
      // litellm at apps/litellm/). Replaces the legacy direct-MLX
      // layout that pointed at 192.168.1.4:8080/8081/8082 — those
      // ports were retired when mlx-server unified to :8090 and
      // litellm took over routing. Model IDs and provider name match
      // the cluster pod's apps/openclaw/configmap.yaml so the local
      // and pod setups stay in sync.
      //
      // For non-cluster local runs, point baseUrl at whatever litellm
      // instance is reachable (e.g., http://localhost:4000/v1 if
      // self-hosted, or the ingress URL if mTLS-tunneled). LITELLM_API_KEY
      // env var is expected — use the local-only virtual key for
      // restricted access, internal-tools for full access incl premium.
      "litellm": {
        baseUrl: "http://litellm.ai-gateway.svc.cluster.local:4000/v1",
        apiKey: "${LITELLM_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "code (Qwen3-Coder-Next-4bit)",
            name: "code — Qwen3-Coder-Next 4bit",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 128000,
            maxTokens: 32768,
          },
          {
            id: "reasoning (Qwen3.6-35B-A3B-4bit)",
            name: "reasoning — Qwen3.6-35B-A3B 4bit (mlx-community)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 128000,
            maxTokens: 32768,
          },
          {
            id: "fast (Qwen3-4B)",
            name: "fast — Qwen3 4B (latency-sensitive)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 128000,
            maxTokens: 32768,
          },
        ],
      },
    },
  },

  cron: {
    enabled: true,
    maxConcurrentRuns: 2,
    sessionRetention: "24h",
  },
}
