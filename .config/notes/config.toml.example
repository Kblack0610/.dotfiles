# notes — profile-aware configuration (read by the `notes` Rust CLI).
#
# Active profile is resolved in this order:
#   1. `--profile <name>` flag
#   2. $NOTES_PROFILE
#   3. [hostname_map] lookup on the short hostname (`hostname -s`)
#   4. default_profile
#
# Paths under a profile are relative to that profile's `root` (── absolute paths
# and a leading `~` are also honored). This file is the SINGLE source of truth for
# "where notes live" — journal-create/aliases/services all read it via the binary.

default_profile = "personal"

[hostname_map]
# Map a machine's short hostname to a profile so corporate boxes auto-root into
# the right directory. Find the name with `hostname -s`, then uncomment + set.
# The GLOBAL default stays "personal" (journal); only corporate boxes opt in here
# so a stray default never reroutes the personal master into the corp dir.
# <corp-machine-hostname> = "AcmeCorp"

# --- Personal vault (default) -------------------------------------------------
[profile.personal]
root      = "~/.notes"
daily     = "journal/daily"
refs      = "journal/refs"
fun       = "journal/backlogs/fun.md"
carryover = "journal/backlogs/carryover.md"
summaries = "journal/summaries"      # → continuous/ and monthly/ live under here
archive   = "journal/daily_archive"
zettel    = "journal/permanent"
meetings  = "journal/meetings"        # `notes meeting new` → structured meeting logs
index     = "journal/index"
inbox     = "inbox"                   # dated captures (/remember, /daily:analysis, `notes inbox add`)
projects  = "lab/projects/current"   # `notes today` auto-links these into ## Current Projects
# Work roster: render a ## Work section with one collapsed line per job - a link to the
# job's latest note and its open-task count (`- AcmeCorp - [[..]] (7 open)`). The tasks
# stay in the job's own note (gf the link to open it); ## Work is regenerated every run,
# separate from ## Focus. Omit = off.
#
# This file is machine-local (the live config.toml is gitignored), so a machine without
# the key never renders ## Work and never strips one another machine wrote.
# rollup  = ["AcmeCorp"]

# --- Corporate machine: root daily notes + refs inside the job's dir ----------
# On a machine set to this profile (via $NOTES_PROFILE or [hostname_map]), `notes
# today` writes into employment/jobs/AcmeCorp/ instead of the personal
# journal. Same git repo — only the active location changes.
[profile.AcmeCorp]
root      = "~/.notes/employment/jobs/AcmeCorp"
daily     = "log"
refs      = "refs"
fun       = "backlogs/fun.md"
carryover = "backlogs/carryover.md"
summaries = "summaries"
archive   = "log_archive"
zettel    = "permanent"
meetings  = "meetings"
index     = "index"
inbox     = "inbox"

# --- Lazer (edubot) — Client engagement -------------------------------------
# Same pattern as AcmeCorp: a corporate job profile that roots daily
# notes inside the Client engagement dir under jobs/lazer/.
[profile.lazer]
root      = "~/.notes/employment/jobs/lazer/client"
daily     = "log"
refs      = "refs"
fun       = "backlogs/fun.md"
carryover = "backlogs/carryover.md"
summaries = "summaries"
archive   = "log_archive"
zettel    = "permanent"
meetings  = "meetings"
index     = "index"
inbox     = "inbox"
