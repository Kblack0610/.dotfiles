.local/bin/opencode-binks-bootstrap
.local/bin/watch-companion-loop
# personal notes/agent systemd units (+ their .target.wants symlinks), both levels
.config/systemd/user/*notes*
.config/systemd/user/*agentctl*
.config/systemd/user/*git-sync*
.config/systemd/user/*journal*
.config/systemd/user/*inbox*
.config/systemd/user/*mqtt*
.config/systemd/user/*regen-project*
.config/systemd/user/*lab-sync*
.config/systemd/user/*/*notes*
.config/systemd/user/*/*agentctl*
.config/systemd/user/*/*git-sync*
.config/systemd/user/*/*journal*
.config/systemd/user/*/*inbox*
.config/systemd/user/*/*mqtt*
.config/systemd/user/*/*regen-project*
.config/systemd/user/*/*lab-sync*

# Agent runtime state — lives in the standalone ~/.agent repo, never tracked here
.agent/
