.oh-my-zsh/

./bin/

src/

!.local/src
.local/src/pxe-server/images
# Local Rust crates (notes-cli, agent-panel, …) keep their sources in the
# conventional src/ dir, which the broad `src/` rule above would otherwise
# swallow. Re-include every .local/src/<crate>/src tree; per-crate .gitignores
# still keep build artifacts (target/) out.
!.local/src/*/src/

# notes: the active profile selection is machine-local — each box copies
# config.toml.example → config.toml and sets its own profile. Only the
# template is tracked, so no machine's choice can ever reroute another's.
.config/notes/config.toml

.local/share/applications/*.desktop

.fonts/.uuid


Media/Pictures
Media/Videos
Media/Music


.config/jesseduffield/lazygit/state.yml

# Unity3d - ignore all editor state
.config/unity3d/

.config/nvim/lazy-lock.json

.config/OrcaSlicer
!.config/OrcaSlicer/OrcaSlicer.conf

# Windsurf - ignore everything except settings
.config/Windsurf/*
!.config/Windsurf/User/
.config/Windsurf/User/*
!.config/Windsurf/User/settings.json

.config/Code/*

.codeium/*
!.codeium/windsurf/
.codeium/windsurf/cascade
.codeium/windsurf/implicit
.codeium/windsurf/installation_id
.codeium/windsurf/codemaps/
!.codeium/windsurf/mcp_config.json
!.codeium/windsurf/user_settings.pb

.cursor/*
!.cursor/mcp.json
!.cursor/user_settings.pb

# Claude Code - DEFAULT-DENY. The personal agent brain (CLAUDE.md, client/infra
# skills, kb-*/release agents) lives in the private overlay ~/.dotfiles-private.
# Only generic, shareable assets are allowlisted below — a NEW skill/agent is
# private unless you add it here, so nothing client-specific auto-publishes.
.claude/*
!.claude/commands/
.claude/commands/kb/
.claude/commands/remember.md
!.claude/hooks/
!.claude/settings.json
# .mcp.json (personal MCP endpoints) lives in the private overlay.
# Skills: allowlist the generic ones (client/infra skills are in the private overlay).
!.claude/skills/
.claude/skills/*
!.claude/skills/compliance/
!.claude/skills/deep-research/
!.claude/skills/deep-research-code/
!.claude/skills/figma-use/
!.claude/skills/gh-workflows/
!.claude/skills/ingest-worktree/
!.claude/skills/marp-slide/
!.claude/skills/notes-system/
!.claude/skills/one-pager/
!.claude/skills/project-index/
!.claude/skills/provision-capture/
!.claude/skills/sentinel/
!.claude/skills/session-snapshot/
!.claude/skills/sprint-overseer/
!.claude/skills/update-rules/
!.claude/skills/wind-down/
!.claude/skills/work-comms/
# Agents: allowlist the generic SuperClaude personas (kb-*/release/overseer are private).
!.claude/agents/
.claude/agents/*
!.claude/agents/backend-architect.md
!.claude/agents/benchmarker.md
!.claude/agents/business-panel-experts.md
!.claude/agents/compliance-counsel.md
!.claude/agents/deep-research-agent.md
!.claude/agents/devops-architect.md
!.claude/agents/frontend-architect.md
!.claude/agents/learning-guide.md
!.claude/agents/monitor.md
!.claude/agents/performance-engineer.md
!.claude/agents/planner.md
!.claude/agents/python-expert.md
!.claude/agents/quality-engineer.md
!.claude/agents/refactoring-expert.md
!.claude/agents/requirements-analyst.md
!.claude/agents/root-cause-analyst.md
!.claude/agents/security-engineer.md
!.claude/agents/socratic-mentor.md
!.claude/agents/system-architect.md
!.claude/agents/technical-writer.md
!.claude/agents/zc-architect.md

# Explicitly never track Claude session/cache data
.claude/.credentials.json
.claude/credentials.json
.claude/profiles/
.claude/debug/
.claude/projects/
.claude/todos/
.claude/history.jsonl
.claude/plugins/
.claude/cache/
.claude/statsig/
.claude/telemetry/
.claude/file-history/
.claude/shell-snapshots/
.claude/paste-cache/
.claude/session-env/
.claude/stats-cache.json
.claude/plans/
.claude/plans.bak/
.claude/downloads/

# Codex - keep repo-managed definitions, ignore local runtime state
.codex/*
!.codex/skills/
!.codex/skills/.system/
!.codex/skills/.system/.codex-system-skills.marker

# Serena 
.serena/*


# Never track: credentials, projects/, session artifacts (todos, debug, file-history, shell-snapshots, statsig, history)
.aider*

# DBeaver - never track connection configs (they carry DB hosts; machine-local + private)
.local/share/DBeaverData/

# k9s - ignore cluster state (may contain sensitive data)
.config/k9s/clusters/

# Kilocode - only track config, not history/logs/workspaces/cache
.kilocode/cli/history.json
.kilocode/cli/logs/
.kilocode/cli/workspaces/
.kilocode/cli/global/cache/

# Playwright MCP runtime
.playwright-mcp/

# Spicetify - keep CustomApps, ignore generated content
.config/spicetify/Extracted/
.config/spicetify/Backup/

# Profile - machine-specific (each machine sets its own via profile-switch)
.config/profile/current

# SSH - never track machine-local overrides or private keys
.ssh/config.local
.ssh/id_*
!.ssh/id_*.pub

# Misc
*.bak
test_notifications.sh

.gemini/

# ── Private overlay — moved to the standalone ~/.dotfiles-private repo ──────────
# These carry client/employer names, infra hosts, or machine-local secrets. They
# are deployed via the private overlay (stowed on top). Never track here.
/AGENTS.md
.k8s-rc
.ssh/config
.ssh/README.md
.bin/csa-firefox-auth-bridge
.config/agentctl/
.config/smug/
.config/infra-dash/
.config/llm-judge/
.config/rulesync-global/
.config/opencode/
.config/shared-hooks/project-map.json
.config/shared-hooks/knowledge-bases.json
.config/firefox/bookmarks/
.config/firefox/simpletabgroups/
.config/firefox/policies.vdi.json
.local/src/ticket/
.local/src/notes-vikunja/
.local/src/meeting-notes/
# personal MCP config + agent/notes tooling kept in place but private-overlaid
.claude/.mcp.json
.config/launchd/
.local/bin/agent-notify
.local/bin/agentctl-dream
.local/bin/agentctl-lab-sync
.local/bin/agentctl-nightly-sync
.local/bin/agentctl-project-index
