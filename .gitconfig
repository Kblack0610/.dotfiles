[user]
	name = Kenneth
	email = kblack0610@gmail.com

# Work identity for anything cloned under ~/dev/.
# The included file is machine-local (not in dotfiles) — see .ssh/README.md.
# Trailing slash matters: scopes to the directory tree.
[includeIf "gitdir:~/dev/"]
	path = ~/.gitconfig-work
[credential]
	helper = store
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[fetch]
	prune = true
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[url "git@bitbucket-nova:"]
	insteadOf = git@bitbucket.org:
[url "ssh://git@bitbucket-nova/"]
	insteadOf = ssh://git@bitbucket.org/
[credential "https://git.kblab.me"]
	helper = store
