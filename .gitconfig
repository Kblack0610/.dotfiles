[user]
	name = Kenneth
	email = kblack0610@gmail.com
[credential]
	helper = osxkeychain
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[fetch]
	prune = true
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://git.kblab.me"]
	helper = osxkeychain
[credential "https://git.kennethblack.me"]
	helper = osxkeychain
# Machine-local overrides (untracked). Holds the Cloudflare Access service-token
# headers for git.kennethblack.me so secrets never land in this tracked file.
# See ~/.gitconfig.local (create per-machine; not stowed).
[include]
	path = ~/.gitconfig.local
