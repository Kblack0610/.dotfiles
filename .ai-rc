# --- AI Tool Aliases & Wrappers ---
# Sourced from .commonrc

# --- Claude Code OpenTelemetry ---
# Ships coding-session metrics + tool-call event logs to the home-k3s Alloy
# DaemonSet's OTLP receiver, which fans out to Prometheus (remote_write) and
# Loki. Claude Code calls Anthropic directly, so this is separate from the
# LiteLLM->Langfuse gateway tracing. Target hp-victus (always-on amd64 k3s node
# running Alloy; static DHCP lease, LAN-DNS name). Alloy binds the OTLP port as
# a hostPort on every node, so any node IP works; hp-victus is the stable pick.
# Guarded on LAN reachability so it silently no-ops off-network (the exporter
# would otherwise fire OTLP batches into the void). The lookup is wrapped in
# `timeout 0.3` because off the home LAN (e.g. on the VDI/corporate network) the
# resolver blocks ~8s on this name before failing, which would hang EVERY new
# shell (.commonrc -> .ai-rc). On-LAN it resolves in a few ms (telemetry on);
# off-LAN it is killed at 0.3s and telemetry stays off, which is the intent.
# Cluster wiring: apps/alloy/{configmap,daemonset}.yaml in home-config.
if timeout 0.3 getent hosts hp-victus >/dev/null 2>&1; then
    export CLAUDE_CODE_ENABLE_TELEMETRY=1
    export OTEL_EXPORTER_OTLP_ENDPOINT=http://hp-victus:4318
    export OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
    export OTEL_METRICS_EXPORTER=otlp
    export OTEL_LOGS_EXPORTER=otlp
    # REQUIRED for the Prometheus path: Claude Code defaults to delta
    # temporality, but otelcol.exporter.prometheus only forwards cumulative -
    # without this, only target_info lands and all counters are silently
    # dropped. (Verified: cumulative makes session/token/cost metrics appear.)
    export OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative
fi

# Claude Code entry point — two-case permission cycle (pairs with settings.json
# "defaultMode": "plan", which boots every session into plan mode):
#   Default (corporate-safe): bypass is NOT offered. Boots in plan; one
#     Shift+Tab toggles plan <-> default (Manual). acceptEdits also sits in
#     the ring — Claude Code has no setting to hide it.
#   CLAUDE_YOLO set (personal): adds bypassPermissions to the cycle via
#     --allow-dangerously-skip-permissions (available, NOT auto-activated), so
#     it still boots in plan and one Shift+Tab lands on bypass.
# Opt in per-machine in an UNTRACKED file (e.g. ~/.bash_profile) with:
#     export CLAUDE_YOLO=1
# Corporate machines leave it unset (the default) — bypass never appears.
claude() {
    if [ -n "$CLAUDE_YOLO" ]; then
        command claude --allow-dangerously-skip-permissions "$@"
    else
        command claude "$@"
    fi
}

alias cl="claude --dangerously-skip-permissions"
alias codex-sync="$HOME/.dotfiles/.config/codex/sync-codex-config.sh"
alias cb="agent" # need to rename to agent

# --- Tmux pane title wrappers for AI tools ---
# Sets ✳ in pane title so tmux agent detection works (like Claude does natively)
# Exports TMUX_PANE_KEY so agents with event APIs can write structured state files
_tmux_agent_wrap() {
    local name="$1"; shift
    if [[ -n "$TMUX" ]]; then
        printf '\033]2;✳ %s\033\\' "$name"
        local sess win
        sess=$(tmux display-message -p '#{session_name}')
        win=$(tmux display-message -p '#{window_index}')
        export TMUX_PANE_KEY="${sess}_${win}"
    fi
    command "$name" "$@"
    if [[ -n "$TMUX" ]]; then
        printf '\033]2;\033\\'
        rm -f "/tmp/agent-events/${TMUX_PANE_KEY}.state.json" 2>/dev/null
        unset TMUX_PANE_KEY
    fi
}
codex()    { _tmux_agent_wrap codex "$@"; }
gemini()   { _tmux_agent_wrap gemini "$@"; }
opencode() { _tmux_agent_wrap opencode "$@"; }
aider()    { _tmux_agent_wrap aider "$@"; }

alias co="codex"
alias claw-setup="$HOME/.dotfiles/.config/openclaw/setup-openclaw.sh"

# --- Claude Code Profiles ---
# Interactive profiles
alias cmt="claude-profile manual-test"    # Browser testing (Playwright, Docker)
alias cim="claude-profile implement"      # Coding (Serena, GitHub, Linear, Context7)
alias cfl="claude-profile full"           # All MCP servers
alias cmn="claude-profile minimal"        # Fast startup (filesystem + memory)

# Headless profiles (for scripting / calling from within Claude)
alias cmt-h="claude-profile manual-test --headless"
alias cim-h="claude-profile implement --headless"
alias cmn-h="claude-profile minimal --headless"
