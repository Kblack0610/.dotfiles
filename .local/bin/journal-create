#!/usr/bin/env bash
# journal-create: Single source of truth for daily journal note creation.
# Creates today's note with Priority/Fun carry-forward and day tracking.
# Usage: journal-create

set -euo pipefail

NOTES_DIR="$HOME/.notes/journal/daily"
REFS_DIR="$HOME/.notes/journal/refs"

# Portable date arithmetic (GNU vs BSD)
date_to_epoch() {
    date -d "$1" +%s 2>/dev/null || date -j -f "%Y-%m-%d" "$1" +%s
}

TODAY=$(date +%Y-%m-%d)
NOTE_FILE="$NOTES_DIR/$TODAY.md"

# Idempotent: exit if today's note exists
[[ -f "$NOTE_FILE" ]] && exit 0

mkdir -p "$NOTES_DIR" "$REFS_DIR/$TODAY"

# --- Extract a markdown section by heading from a file ---
# Returns lines between "## $section" and the next "## " (exclusive), skipping blanks
extract_section() {
    local file="$1" section="$2"
    sed -n "/^## ${section}$/,/^## /{/^## /d; p;}" "$file" | sed '/^$/d'
}

# --- Process carry-forward items: drop checked, stamp day tracking ---
stamp_items() {
    local prev_date="$1"
    local today_epoch
    today_epoch=$(date_to_epoch "$TODAY")

    while IFS= read -r line; do
        # Drop checked items
        if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*\[[xX]\] ]]; then
            continue
        fi

        # Drop empty task placeholders ("- [ ]" with no content)
        if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*\[\ \][[:space:]]*$ ]]; then
            continue
        fi

        # Process unchecked task lines
        if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*\[ ]]; then
            if [[ "$line" =~ \<!--\ since:([0-9]{4}-[0-9]{2}-[0-9]{2})\ --\> ]]; then
                # Has origin date -- recompute (Nd) suffix
                local origin="${BASH_REMATCH[1]}"
                local origin_epoch
                origin_epoch=$(date_to_epoch "$origin")
                local days=$(( (today_epoch - origin_epoch) / 86400 ))
                # Remove old (Nd) suffix, add updated one
                line=$(echo "$line" | sed 's/ ([0-9]*d)//')
                line=$(echo "$line" | sed "s| <!-- since:| (${days}d) <!-- since:|")
            else
                # New carry-forward item -- stamp with prev_date as origin
                local origin_epoch
                origin_epoch=$(date_to_epoch "$prev_date")
                local days=$(( (today_epoch - origin_epoch) / 86400 ))
                line="$line (${days}d) <!-- since:${prev_date} -->"
            fi
        fi
        # Output the line (task lines stamped, non-task lines like sub-items pass through)
        echo "$line"
    done
}

# --- Find most recent previous note ---
PREV_FILE=$(ls -1 "$NOTES_DIR/"*.md 2>/dev/null | sort | grep -v "$TODAY" | tail -1)

PRIORITY_ITEMS=""
FUN_ITEMS=""
CARRYOVER_ITEMS=""
PROJECTS_ITEMS=""

if [[ -n "${PREV_FILE:-}" ]] && [[ -f "$PREV_FILE" ]]; then
    # Extract date from previous filename for day-tracking origin
    PREV_DATE=$(basename "$PREV_FILE" .md)

    RAW_PRIORITY=$(extract_section "$PREV_FILE" "Priority")
    RAW_FUN=$(extract_section "$PREV_FILE" "Fun")
    RAW_FOCUS=$(extract_section "$PREV_FILE" "Focus")
    RAW_CARRYOVER=$(extract_section "$PREV_FILE" "Carry Over")
    # Carry Current Projects verbatim so user-curated version links survive
    PROJECTS_ITEMS=$(extract_section "$PREV_FILE" "Current Projects")

    if [[ -n "$RAW_PRIORITY" ]]; then
        PRIORITY_ITEMS=$(echo "$RAW_PRIORITY" | stamp_items "$PREV_DATE")
    fi
    if [[ -n "$RAW_FUN" ]]; then
        FUN_ITEMS=$(echo "$RAW_FUN" | stamp_items "$PREV_DATE")
    fi

    # Carry Over accumulates: unchecked items from previous Focus + previous Carry Over
    # User triages these daily into Focus/Priority/discard
    COMBINED_CARRYOVER=""
    if [[ -n "$RAW_FOCUS" ]]; then
        COMBINED_CARRYOVER="$RAW_FOCUS"
    fi
    if [[ -n "$RAW_CARRYOVER" ]]; then
        if [[ -n "$COMBINED_CARRYOVER" ]]; then
            COMBINED_CARRYOVER="$COMBINED_CARRYOVER"$'\n'"$RAW_CARRYOVER"
        else
            COMBINED_CARRYOVER="$RAW_CARRYOVER"
        fi
    fi
    if [[ -n "$COMBINED_CARRYOVER" ]]; then
        CARRYOVER_ITEMS=$(echo "$COMBINED_CARRYOVER" | stamp_items "$PREV_DATE")
    fi
fi

# --- Write the daily note ---
{
    echo "---"
    echo "date: $TODAY"
    echo "tags: [daily]"
    echo "---"
    echo ""
    echo "# $TODAY"
    echo ""
    echo "## Current Projects"
    if [[ -n "$PROJECTS_ITEMS" ]]; then
        echo "$PROJECTS_ITEMS"
    else
        PROJECTS_DIR="$HOME/.notes/dev/projects"
        if [[ -d "$PROJECTS_DIR" ]]; then
            for entry in "$PROJECTS_DIR"/*/; do
                [[ -d "$entry" ]] || continue
                name=$(basename "$entry")
                [[ "$name" == "archived" ]] && continue
                echo "- [[dev/projects/${name}/summary.md|${name}]]"
            done
        fi
    fi
    echo ""
    echo "## Focus"
    echo "- [ ] "
    echo ""
    echo "## Notes"
    echo ""
    echo "## Priority"
    if [[ -n "$PRIORITY_ITEMS" ]]; then
        echo "$PRIORITY_ITEMS"
    fi
    echo ""
    echo "## Fun"
    if [[ -n "$FUN_ITEMS" ]]; then
        echo "$FUN_ITEMS"
    fi
    echo ""
    echo "## Carry Over"
    if [[ -n "$CARRYOVER_ITEMS" ]]; then
        echo "$CARRYOVER_ITEMS"
    fi
    echo ""
} > "$NOTE_FILE"

# Report what was carried
[[ -n "$PRIORITY_ITEMS" ]] && echo "  -> Carried over priority items"
[[ -n "$FUN_ITEMS" ]] && echo "  -> Carried over fun items"
[[ -n "$CARRYOVER_ITEMS" ]] && echo "  -> Carried over focus/carryover items"
