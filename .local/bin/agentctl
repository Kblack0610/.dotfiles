#!/usr/bin/env bash
# agentctl — manage named long-running Claude agents via systemd --user
#
# Each agent is a config file at ~/.config/agentctl/agents/<name>.conf.
# Agents become systemctl --user units (agentctl@<name>.service for the
# process; agentctl-<name>.timer for oneshot scheduling).

set -euo pipefail

CONFIG_DIR="${HOME}/.config/agentctl/agents"
SYSTEMD_USER_DIR="${HOME}/.config/systemd/user"
STATE_DIR="${HOME}/.local/state/agentctl"

mkdir -p "$STATE_DIR"

die() { printf 'agentctl: %s\n' "$*" >&2; exit 1; }

list_agent_names() {
    [ -d "$CONFIG_DIR" ] || return 0
    for f in "$CONFIG_DIR"/*.conf; do
        [ -f "$f" ] || continue
        basename "$f" .conf
    done
}

# Source a config in a subshell, validate, emit normalized KEY=VALUE lines.
load_agent() {
    local name="$1"
    local conf="$CONFIG_DIR/${name}.conf"
    [ -f "$conf" ] || { printf 'no such agent: %s\n' "$name" >&2; return 1; }
    (
        set -e
        # shellcheck disable=SC1090
        source "$conf"
        : "${NAME:?missing NAME}"
        : "${KIND:?missing KIND}"
        : "${COMMAND:?missing COMMAND}"
        case "$KIND" in
            oneshot|persistent) ;;
            *) printf 'invalid KIND=%s\n' "$KIND" >&2; exit 1 ;;
        esac
        [ "$NAME" = "$name" ] || { printf 'NAME=%s does not match filename %s\n' "$NAME" "$name" >&2; exit 1; }
        : "${DESCRIPTION:=}"
        : "${SCHEDULE:=}"
        : "${AUTOSTART:=no}"
        : "${INBOX:=$HOME/.notes/inbox/$NAME}"
        printf 'NAME=%s\n' "$NAME"
        printf 'KIND=%s\n' "$KIND"
        printf 'COMMAND=%s\n' "$COMMAND"
        printf 'DESCRIPTION=%s\n' "$DESCRIPTION"
        printf 'SCHEDULE=%s\n' "$SCHEDULE"
        printf 'AUTOSTART=%s\n' "$AUTOSTART"
        printf 'INBOX=%s\n' "$INBOX"
    )
}

agent_field() {
    local name="$1" field="$2"
    load_agent "$name" 2>/dev/null \
        | awk -F= -v k="$field" 'BEGIN{IGNORECASE=0} {if (substr($0,1,length(k)+1) == k"=") {print substr($0, length(k)+2); exit}}'
}

systemd_show() {
    local unit="$1" prop="$2"
    systemctl --user show "$unit" --property="$prop" --value 2>/dev/null
}

unit_state() { systemd_show "agentctl@${1}.service" ActiveState; }
unit_substate() { systemd_show "agentctl@${1}.service" SubState; }
unit_result() { systemd_show "agentctl@${1}.service" Result; }
unit_restarts() { systemd_show "agentctl@${1}.service" NRestarts; }
unit_exitstatus() { systemd_show "agentctl@${1}.service" ExecMainStatus; }

unit_pid() {
    local pid
    pid=$(systemd_show "agentctl@${1}.service" MainPID)
    [ "$pid" = "0" ] && echo "" || echo "$pid"
}

unit_uptime() {
    local started
    started=$(systemd_show "agentctl@${1}.service" ExecMainStartTimestamp)
    if [ -z "$started" ] || [ "$started" = "n/a" ]; then
        echo ""; return 0
    fi
    local started_epoch now_epoch diff
    if ! started_epoch=$(date -d "$started" +%s 2>/dev/null); then
        echo ""; return 0
    fi
    now_epoch=$(date +%s)
    diff=$((now_epoch - started_epoch))
    if [ "$diff" -lt 0 ]; then
        echo ""; return 0
    fi
    fmt_dur "$diff"
}

unit_next_run() {
    local timer="agentctl-${1}.timer"
    # systemd output: "Fri 2026-05-01 03:00:00 PDT      11h -  ..."
    # Show "Fri 03:00:00" as a compact next-run marker.
    systemctl --user list-timers --all 2>/dev/null \
        | awk -v t="$timer" '$0 ~ t {print $1" "$3; exit}'
}

fmt_dur() {
    local s=$1
    if   [ "$s" -lt 60 ];    then printf '%ds\n' "$s"
    elif [ "$s" -lt 3600 ];  then printf '%dm%ds\n' $((s/60)) $((s%60))
    elif [ "$s" -lt 86400 ]; then printf '%dh%dm\n' $((s/3600)) $(((s%3600)/60))
    else                          printf '%dd%dh\n' $((s/86400)) $(((s%86400)/3600))
    fi
}

# ----------------------------------------------------------------------
# Subcommands
# ----------------------------------------------------------------------

cmd_list() {
    printf '%-12s %-10s %-10s %-7s %-10s %s\n' NAME KIND STATE PID UPTIME NEXT
    local found=0
    while IFS= read -r name; do
        [ -n "$name" ] || continue
        found=1
        local kind state pid uptime nextrun
        kind=$(agent_field "$name" KIND)
        [ -z "$kind" ] && kind="?"
        state=$(unit_state "$name"); [ -z "$state" ] && state="-"
        pid=$(unit_pid "$name");     [ -z "$pid" ]   && pid="-"
        uptime=$(unit_uptime "$name"); [ -z "$uptime" ] && uptime="-"
        nextrun=$(unit_next_run "$name"); [ -z "$nextrun" ] && nextrun="-"
        printf '%-12s %-10s %-10s %-7s %-10s %s\n' "$name" "$kind" "$state" "$pid" "$uptime" "$nextrun"
    done < <(list_agent_names)
    if [ "$found" -eq 0 ]; then
        printf '(no agents configured at %s)\n' "$CONFIG_DIR"
    fi
    return 0
}

cmd_status() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: agentctl status <name>"
    [ -f "$CONFIG_DIR/${name}.conf" ] || die "no such agent: $name"

    local desc kind inbox state substate pid uptime restarts result lastexit nextrun
    desc=$(agent_field "$name" DESCRIPTION)
    kind=$(agent_field "$name" KIND)
    inbox=$(agent_field "$name" INBOX)
    state=$(unit_state "$name")
    substate=$(unit_substate "$name")
    pid=$(unit_pid "$name")
    uptime=$(unit_uptime "$name")
    restarts=$(unit_restarts "$name")
    result=$(unit_result "$name")
    lastexit=$(unit_exitstatus "$name")
    nextrun=$(unit_next_run "$name")

    printf '%s [%s]\n' "$name" "$kind"
    [ -n "$desc" ] && printf '  description: %s\n' "$desc"
    printf '  state:    %s' "${state:-unknown}"
    [ -n "$substate" ] && [ "$substate" != "$state" ] && printf ' (%s)' "$substate"
    printf '\n'
    [ -n "$pid" ]      && printf '  pid:      %s\n' "$pid"
    [ -n "$uptime" ]   && printf '  uptime:   %s\n' "$uptime"
    [ -n "$restarts" ] && [ "$restarts" != "0" ] && printf '  restarts: %s\n' "$restarts"
    [ -n "$result" ]   && [ "$result" != "success" ] && printf '  result:   %s\n' "$result"
    if [[ -n "$lastexit" && "$state" != "active" && ( "$result" != "success" || -n "$pid" ) ]]; then
        printf '  last_exit: %s\n' "$lastexit"
    fi
    [ -n "$nextrun" ]  && printf '  next_run: %s\n' "$nextrun"
    printf '  inbox:    %s\n' "$inbox"

    local stdout="$STATE_DIR/${name}.stdout.log"
    local stderr="$STATE_DIR/${name}.stderr.log"
    local activity="$inbox/activity.log"
    if [ -s "$stdout" ]; then
        printf '\n--- stdout (tail 10) ---\n'
        tail -n 10 "$stdout"
    fi
    if [ -s "$stderr" ]; then
        printf '\n--- stderr (tail 10) ---\n'
        tail -n 10 "$stderr"
    fi
    if [ -s "$activity" ]; then
        printf '\n--- inbox activity (tail 10) ---\n'
        tail -n 10 "$activity"
    fi
}

cmd_start() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: agentctl start <name>"
    [ -f "$CONFIG_DIR/${name}.conf" ] || die "no such agent: $name"
    systemctl --user start "agentctl@${name}.service"
}

cmd_stop() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: agentctl stop <name>"
    systemctl --user stop "agentctl@${name}.service"
}

cmd_restart() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: agentctl restart <name>"
    [ -f "$CONFIG_DIR/${name}.conf" ] || die "no such agent: $name"
    systemctl --user restart "agentctl@${name}.service"
}

cmd_enable() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: agentctl enable <name>"
    [ -f "$CONFIG_DIR/${name}.conf" ] || die "no such agent: $name"
    local kind
    kind=$(agent_field "$name" KIND)
    if [ "$kind" = "oneshot" ]; then
        [ -f "$SYSTEMD_USER_DIR/agentctl-${name}.timer" ] \
            || die "no timer for $name; run 'agentctl reload' first"
        systemctl --user enable --now "agentctl-${name}.timer"
    else
        systemctl --user enable --now "agentctl@${name}.service"
    fi
}

cmd_disable() {
    local name="${1:-}"
    [ -n "$name" ] || die "usage: agentctl disable <name>"
    local kind
    kind=$(agent_field "$name" KIND 2>/dev/null || echo "")
    if [ "$kind" = "oneshot" ]; then
        systemctl --user disable --now "agentctl-${name}.timer" 2>/dev/null || true
    else
        systemctl --user disable --now "agentctl@${name}.service" 2>/dev/null || true
    fi
}

cmd_logs() {
    local follow=""
    local name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--follow) follow=1; shift ;;
            -*) die "unknown option: $1" ;;
            *)  name="$1"; shift ;;
        esac
    done
    [ -n "$name" ] || die "usage: agentctl logs <name> [-f]"
    [ -f "$CONFIG_DIR/${name}.conf" ] || die "no such agent: $name"

    local inbox stdout stderr activity
    inbox=$(agent_field "$name" INBOX)
    stdout="$STATE_DIR/${name}.stdout.log"
    stderr="$STATE_DIR/${name}.stderr.log"
    activity="$inbox/activity.log"

    mkdir -p "$STATE_DIR" "$inbox"
    [ -e "$stdout" ]   || touch "$stdout"
    [ -e "$stderr" ]   || touch "$stderr"
    [ -e "$activity" ] || touch "$activity"

    if [ -n "$follow" ]; then
        exec tail -F "$stdout" "$stderr" "$activity"
    else
        tail -n 50 "$stdout" "$stderr" "$activity"
    fi
}

write_timer_file() {
    local name="$1" schedule="$2"
    local timer="$SYSTEMD_USER_DIR/agentctl-${name}.timer"
    cat > "$timer" <<EOF
[Unit]
Description=agentctl schedule: $name
# Generated by 'agentctl reload' — do not edit manually.

[Timer]
OnCalendar=$schedule
Persistent=true
Unit=agentctl@${name}.service

[Install]
WantedBy=timers.target
EOF
}

cmd_reload() {
    mkdir -p "$SYSTEMD_USER_DIR" "$STATE_DIR"

    local existing_timers=()
    for t in "$SYSTEMD_USER_DIR"/agentctl-*.timer; do
        [ -f "$t" ] || continue
        existing_timers+=("$(basename "$t" .timer | sed 's/^agentctl-//')")
    done

    local configured_oneshots=()
    local configured_persistent_autostart=()
    local count=0 errors=0
    while IFS= read -r name; do
        [ -n "$name" ] || continue
        if ! load_agent "$name" >/dev/null 2>&1; then
            local err
            err=$(load_agent "$name" 2>&1 1>/dev/null || true)
            printf 'agentctl: skipping invalid config %s: %s\n' "$name" "$err" >&2
            errors=$((errors + 1))
            continue
        fi
        count=$((count + 1))
        local kind sched autostart
        kind=$(agent_field "$name" KIND)
        sched=$(agent_field "$name" SCHEDULE)
        autostart=$(agent_field "$name" AUTOSTART)

        if [ "$kind" = "oneshot" ] && [ -n "$sched" ]; then
            write_timer_file "$name" "$sched"
            configured_oneshots+=("$name")
        elif [ "$kind" = "persistent" ] && [ "$autostart" = "yes" ]; then
            configured_persistent_autostart+=("$name")
        fi
    done < <(list_agent_names)

    # Remove orphaned timers
    if [ "${#existing_timers[@]}" -gt 0 ]; then
        for t in "${existing_timers[@]}"; do
            local found=0
            if [ "${#configured_oneshots[@]}" -gt 0 ]; then
                for o in "${configured_oneshots[@]}"; do
                    [ "$o" = "$t" ] && { found=1; break; }
                done
            fi
            if [ "$found" -eq 0 ]; then
                systemctl --user disable --now "agentctl-${t}.timer" 2>/dev/null || true
                rm -f "$SYSTEMD_USER_DIR/agentctl-${t}.timer"
                printf 'agentctl: removed orphan timer: %s\n' "$t" >&2
            fi
        done
    fi

    systemctl --user daemon-reload

    if [ "${#configured_oneshots[@]}" -gt 0 ]; then
        for o in "${configured_oneshots[@]}"; do
            systemctl --user enable "agentctl-${o}.timer" >/dev/null 2>&1 || true
            systemctl --user start  "agentctl-${o}.timer" >/dev/null 2>&1 || true
        done
    fi
    if [ "${#configured_persistent_autostart[@]}" -gt 0 ]; then
        for p in "${configured_persistent_autostart[@]}"; do
            systemctl --user enable "agentctl@${p}.service" >/dev/null 2>&1 || true
            local state
            state=$(unit_state "$p")
            if [ "$state" != "active" ]; then
                systemctl --user start "agentctl@${p}.service" >/dev/null 2>&1 || true
            fi
        done
    fi

    printf 'agentctl: loaded %d agent(s)' "$count"
    [ "$errors" -gt 0 ] && printf ', %d error(s)' "$errors"
    printf '\n'
}

cmd_watch() {
    command -v watch >/dev/null || die "watch(1) not found (install procps-ng)"
    exec watch -n 2 -c -t -- agentctl list
}

cmd_help() {
    cat <<'EOF'
agentctl — manage named long-running Claude agents via systemd

Usage:
  agentctl list                  List all configured agents and their state
  agentctl status <name>         Detailed status for one agent
  agentctl start <name>          Start agent (oneshot: run now; persistent: spawn)
  agentctl stop <name>           Stop a running agent
  agentctl restart <name>        Restart agent
  agentctl enable <name>         Enable agent (autostart on boot, or arm timer)
  agentctl disable <name>        Disable agent
  agentctl logs <name> [-f]      Tail merged stdout+stderr+inbox (use -f to follow)
  agentctl reload                Rescan agents/, regenerate timers, daemon-reload
  agentctl watch                 Refreshing dashboard (Ctrl-C to exit)

Configs live at ~/.config/agentctl/agents/<name>.conf.
See ~/.config/agentctl/README.md for the schema.
EOF
}

# ----------------------------------------------------------------------
# Dispatch
# ----------------------------------------------------------------------

case "${1:-}" in
    list)              cmd_list ;;
    status)            shift; cmd_status "$@" ;;
    start)             shift; cmd_start "$@" ;;
    stop)              shift; cmd_stop "$@" ;;
    restart)           shift; cmd_restart "$@" ;;
    enable)            shift; cmd_enable "$@" ;;
    disable)           shift; cmd_disable "$@" ;;
    logs)              shift; cmd_logs "$@" ;;
    reload)            cmd_reload ;;
    watch)             cmd_watch ;;
    help|--help|-h|"") cmd_help ;;
    *)                 die "unknown subcommand: $1 (see 'agentctl help')" ;;
esac
