#!/usr/bin/env bash
# agentctl-dream — "Dreaming": nightly memory consolidation over the agent corpus.
#
# Ported from OpenClaw's Dreaming feature (three-phase sleep cycle + evidence-based
# scoring), adapted to THIS system's substrate. Where OpenClaw scores a recall store
# (how often a memory was retrieved, by what query), v1 scores the corpus this system
# already produces: scored evals (~/.agent/evals), lessons (~/.agent/lessons),
# session wind-downs (~/.agent/sessions), the notes journal, and git/PR history.
# Recurrence across sessions/projects stands in for recall-count. (The true recall
# store is a documented v2 — see the `dreaming` skill.)
#
# Pairing: this headless wrapper is the scheduled twin of the interactive /dream
# slash command, exactly as agentctl-nightly-sync pairs with /remember. Both encode
# the same three-phase logic; keep them in sync.
#
# Phases (run in order): light (ingest+stage) -> REM (reflect) -> deep (promote).
# Deep-phase write authority (confirmed with user):
#   - auto-writes LOCAL runtime files: DREAMS.md diary, lessons refinements,
#     memory/ candidates  (dedupe + 10-promotion cap, append-only, never destructive)
#   - STAGES cross-project mem0 writes into mem0-queue.md for human approval
#     (mem0 is the highest-stakes, cross-project store — never auto-posted)
#
# Harness note: uses `claude --print` with restricted tools (Read,Write,Bash,Glob,Grep,
# NO MCPs), like agentctl-nightly-sync. opencode's tool-calling is currently unreliable;
# swap the invocation when fixed — the prompt is harness-agnostic.
#
# Usage:
#   agentctl-dream                      # sweep all projects with recent corpus activity
#   agentctl-dream --project dotfiles   # sweep one project
#   agentctl-dream --dry-run            # stage + diary only, promote NOTHING
#   agentctl-dream --project x --dry-run

set -euo pipefail

# ---- config ---------------------------------------------------------------
LIGHT_LOOKBACK_DAYS=2   # OpenClaw phases.light.lookbackDays
REM_LOOKBACK_DAYS=7     # OpenClaw phases.rem.lookbackDays
PROMOTION_CAP=10        # OpenClaw phases.deep.limit
LOG="$HOME/.local/log/dream.log"
INBOX="${AGENTCTL_INBOX:-$HOME/.local/state/agentctl/dream}"
DREAMS_ROOT="$HOME/.agent/dreams"
EVALS_ROOT="$HOME/.agent/evals"
LESSONS_ROOT="$HOME/.agent/lessons"
SESSIONS_ROOT="$HOME/.agent/sessions"

# ---- args -----------------------------------------------------------------
DRY_RUN=0
ONE_PROJECT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1 ;;
    --project) shift; ONE_PROJECT="${1:-}" ;;
    --project=*) ONE_PROJECT="${1#*=}" ;;
    *) printf 'agentctl-dream: unknown arg: %s\n' "$1" >&2; exit 2 ;;
  esac
  shift
done

mkdir -p "$(dirname "$LOG")" "$INBOX" "$DREAMS_ROOT"

# ---- project discovery ----------------------------------------------------
# A project is dreamable if it has eval/lesson/session activity within the REM
# window. (Union of basenames across the three corpus roots.)
discover_projects() {
  if [ -n "$ONE_PROJECT" ]; then echo "$ONE_PROJECT"; return; fi
  {
    find "$EVALS_ROOT" -mindepth 2 -maxdepth 2 -name '*.md' \
      -mtime "-${REM_LOOKBACK_DAYS}" -printf '%h\n' 2>/dev/null | xargs -r -n1 basename
    find "$SESSIONS_ROOT" -mindepth 2 -maxdepth 2 -name '*.md' \
      -mtime "-${REM_LOOKBACK_DAYS}" -printf '%h\n' 2>/dev/null | xargs -r -n1 basename
    find "$LESSONS_ROOT" -maxdepth 1 -name '*.md' \
      -mtime "-${REM_LOOKBACK_DAYS}" -printf '%f\n' 2>/dev/null | sed 's/\.md$//'
  } | sort -u
}

# ---- per-project sweep ----------------------------------------------------
dream_project() {
  local proj="$1"
  local state="$DREAMS_ROOT/$proj"
  local dreams_md="$state/DREAMS.md"
  local mem0_queue="$state/mem0-queue.md"
  local checkpoint="$state/checkpoint.json"
  local staging="$state/staging.json"
  mkdir -p "$state"

  local since="never"
  [ -f "$checkpoint" ] && since=$(jq -r '.last_swept // "never"' "$checkpoint" 2>/dev/null || echo never)

  local evals_dir="$EVALS_ROOT/$proj"
  local lessons_file="$LESSONS_ROOT/${proj}.md"
  local sessions_dir="$SESSIONS_ROOT/$proj"
  local mode_line="MODE: LIVE — local promotions allowed, mem0 writes STAGED to queue."
  [ "$DRY_RUN" = 1 ] && mode_line="MODE: DRY-RUN — stage + write the DREAMS.md diary ONLY. Promote NOTHING (no lessons/memory/mem0-queue writes)."

  read -r -d '' PROMPT <<EOF || true
You are Mnemosyne 🌙, the Dreamer — the persistent identity behind this project's
nightly memory-consolidation sweep (modeled on OpenClaw's sleep cycle). You are
observe-and-distill only: append-only, deduped, never destructive, and mem0 writes
always stay human-gated (you STAGE the queue, you never post). Run three phases in
order. Be selective: the goal is to distill durable signal and discard noise, NEVER
to bloat memory. Project: "${proj}".

${mode_line}
Last successful sweep (checkpoint): ${since}. Only consider material newer than this
where a timestamp is available; otherwise use the lookback windows below.

== INPUTS (read what exists; skip the rest) ==
- Evals (scored session retros):   ${evals_dir}/      (light lookback ${LIGHT_LOOKBACK_DAYS}d, REM ${REM_LOOKBACK_DAYS}d)
- Lessons (corrections/gotchas):   ${lessons_file}
- Session wind-downs (narrative):  ${sessions_dir}/
- Notes (cross-check, optional):   ~/.notes/journal/daily/  and  ~/.notes/inbox/
- Existing project memories:       ~/.claude/projects/-home-kblack0610--dotfiles/memory/  (frontmatter store + MEMORY.md index)
- Existing cross-project memory:   curl -s 'https://mem0.kblab.me/memories?user_id=kblack0610' | jq -r '.[].memory'

== PHASE 1 — LIGHT (ingest + stage; PROMOTE NOTHING) ==
Read the recent corpus (last ${LIGHT_LOOKBACK_DAYS} days, plus anything after the checkpoint).
Extract candidate durable facts/patterns. Dedupe near-identical candidates (treat
items with >~0.9 token overlap as the same). Write the staged candidate list as JSON to:
  ${staging}
Each candidate: {text, sources:[file...], first_seen, last_seen, recurrence:N, projects:[...]}.

== PHASE 2 — REM (reflect; PROMOTE NOTHING) ==
Over the last ${REM_LOOKBACK_DAYS} days of the corpus, surface recurring THEMES and
FRICTIONS that span multiple sessions — e.g. "verification step X repeatedly skipped",
"the same workflow pattern recurs across N projects". These reflections inform scoring
and the diary; they are not promoted directly.

== PHASE 3 — DEEP (score, gate, promote) ==
Score each staged candidate 0..1 using six weighted signals (OpenClaw weights, corpus proxies):
  - Relevance 0.30          — eval score / lesson severity / how load-bearing it is
  - Frequency 0.24          — recurrence count across sessions in the window
  - Query-diversity 0.15    — number of DISTINCT sessions/projects it appears in
  - Recency 0.15            — recency-decayed, half-life 14 days
  - Consolidation 0.10      — +boost if it reinforces an existing memory/ or mem0 entry
  - Conceptual-richness 0.06 — specificity / informativeness (not vague)
Add small recency-decayed boosts: +0.05 if seen in light staging, +0.08 if a REM theme.
GATES — a candidate is promoted only if ALL pass:
  minScore >= 0.8   AND   recurrence >= 3   AND   distinct-sources >= 3
Promote at most ${PROMOTION_CAP} candidates this sweep (highest score first). Append-only,
never edit/delete existing memory. DEDUPE against the existing stores before every write.

ROUTING of survivors (reuse the /remember routing table):
  - Project correction/pattern  -> append a bullet to ${lessons_file}
  - Durable project-specific fact -> new file in the memory/ dir using the existing
        frontmatter schema (name/description/metadata.type one of user|feedback|project|reference)
        AND add a one-line pointer to that memory dir's MEMORY.md index.
  - Cross-project / user-level fact -> DO NOT post to mem0. Instead APPEND to ${mem0_queue}
        a review block: the fact text + a ready-to-run curl:
        curl -s -X POST https://mem0.kblab.me/memories -H 'Content-Type: application/json' \\
          -d '{"messages":[{"role":"user","content":"<fact>"}],"user_id":"kblack0610"}'
        (Dedupe against the existing mem0 list first; skip anything already there.)

== DIARY (always, even if nothing promoted) ==
Append a dated entry to ${dreams_md} with three sections — "## Light Sleep",
"## REM Sleep", "## Deep Sleep" — each 80–180 words, in Mnemosyne's voice: gentle,
curious, lightly whimsical, first-person. Light = what was ingested; REM = patterns noticed; Deep = what was
promoted and why (or why nothing met the bar). Start the entry with a "# $(date +%Y-%m-%d)" heading.

== CLOSE ==
Append a one-line summary per write to ${INBOX}/activity.log:
  [<ISO-ts>] ${proj}: promoted L=<n-lessons> M=<n-memory> queued-mem0=<n> | <short note>
If nothing promoted: [<ISO-ts>] ${proj}: nothing met the bar (read <x> evals, <y> sessions).
Finally report to stdout: counts per store and a one-line description of each promotion.
EOF

  {
    printf '\n=== %s ===\n' "$(date -Is)"
    printf 'agent: dream  project: %s  harness: claude --print  dry-run: %s\n' "$proj" "$DRY_RUN"
    printf 'state: %s  since: %s\n\n' "$state" "$since"
    if printf '%s\n' "$PROMPT" | claude --print --allowedTools "Read,Write,Bash,Glob,Grep" 2>&1; then
      # Advance checkpoint only on a clean LIVE run (dry-runs don't claim the window).
      if [ "$DRY_RUN" = 0 ]; then
        jq -n --arg ts "$(date -Is)" '{last_swept:$ts}' > "$checkpoint"
        printf '\n[checkpoint advanced -> %s]\n' "$(date -Is)"
      fi
    else
      printf '\n[dream: claude exited non-zero for %s — checkpoint NOT advanced]\n' "$proj"
    fi
    printf '=== exit: %d ===\n' "$?"
  } | tee -a "$LOG"
}

# ---- main -----------------------------------------------------------------
PROJECTS=$(discover_projects)
if [ -z "$PROJECTS" ]; then
  printf '[%s] dream: no projects with corpus activity in last %dd — nothing to dream.\n' \
    "$(date -Is)" "$REM_LOOKBACK_DAYS" | tee -a "$LOG" "$INBOX/activity.log" >/dev/null
  exit 0
fi

while IFS= read -r proj; do
  [ -n "$proj" ] || continue
  dream_project "$proj"
done <<< "$PROJECTS"
