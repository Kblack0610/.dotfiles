#!/usr/bin/env bash
# journal-carryforward: Extract incomplete tasks from yesterday and summarize with local LLM
# Outputs separate ## Priority and ## Fun sections
# Usage: journal-carryforward

set -euo pipefail

OLLAMA_URL="${OLLAMA_URL:-http://192.168.1.4:11434}"
OLLAMA_MODEL="${OLLAMA_MODEL:-qwen3-coder:30b}"
NOTES_DIR="$HOME/.notes/journal/daily"

TODAY=$(date +%Y-%m-%d)
YESTERDAY=$(date -d "yesterday" +%Y-%m-%d 2>/dev/null || date -v -1d +%Y-%m-%d)
YESTERDAY_FILE="$NOTES_DIR/$YESTERDAY.md"

# Exit silently if no yesterday's note
[[ ! -f "$YESTERDAY_FILE" ]] && exit 0

# Extract a section's incomplete tasks
extract_incomplete() {
    local file="$1" section="$2"
    sed -n "/^## ${section}$/,/^## /{/^## /d; p;}" "$file" \
        | grep -E '^\s*-\s*\[\s*\]' 2>/dev/null || true
}

PRIORITY=$(extract_incomplete "$YESTERDAY_FILE" "Priority")
FUN=$(extract_incomplete "$YESTERDAY_FILE" "Fun")

# Migration: fall back to old "Carry Over" section
if [[ -z "$PRIORITY" ]] && [[ -z "$FUN" ]]; then
    PRIORITY=$(extract_incomplete "$YESTERDAY_FILE" "Carry Over")
fi

# Exit if nothing to carry
[[ -z "$PRIORITY" ]] && [[ -z "$FUN" ]] && exit 0

# Build LLM prompt
PROMPT="Incomplete tasks from $YESTERDAY to carry forward to $TODAY.
Prioritize and group related items within each section. Keep markdown checkbox format (- [ ]).
Preserve any HTML comments (<!-- since:... -->) at the end of each line exactly as they appear.
Just output the task lists, no explanations.

## Priority tasks:
${PRIORITY:-None}

## Fun tasks:
${FUN:-None}

Output format (include both headings even if a section is empty):
## Priority
<items>

## Fun
<items>"

# Call Ollama
RESPONSE=$(curl -s --max-time 30 "$OLLAMA_URL/api/generate" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg m "$OLLAMA_MODEL" --arg p "$PROMPT" \
        '{model: $m, prompt: $p, stream: false}')" 2>/dev/null || true)

SUMMARY=$(echo "$RESPONSE" | jq -r '.response // empty' 2>/dev/null || true)

if [[ -n "$SUMMARY" ]]; then
    echo "$SUMMARY"
else
    # Fallback: output raw items in two sections
    echo "## Priority"
    [[ -n "$PRIORITY" ]] && echo "$PRIORITY"
    echo ""
    echo "## Fun"
    [[ -n "$FUN" ]] && echo "$FUN"
fi
