#!/usr/bin/env bash
# captain-watchdog — autonomous, observe-only sprint watch for the captain skill.
#
# The captain's watchdog is the captain's duty, not the user's. When a sprint is
# active this runs a headless `/captain watch` pass on a timer so status +
# notifications happen without the user keeping a session open. `watch` never
# executes (no dispatch/merge/tag), so automating it is safe.
#
# Subcommands:
#   arm      install + start a systemd --user timer that runs `run` every ~12 min
#   disarm   stop + remove the timer
#   run      one pass: if an active sprint exists → headless `/captain watch`;
#            else self-disarm and exit 0
#   status   print whether the timer is active and whether a sprint is active
#
# Config (env overrides):
#   CAPTAIN_REPO   repo dir            (default: /home/kblack0610/dev/bnb/platform)
#   CAPTAIN_MODEL  model for the pass  (default: claude-sonnet-4-6 — cheap; the
#                  settings.json fallbackModel chain still applies)
#   CAPTAIN_INTERVAL  timer cadence    (default: 12min)
set -euo pipefail

REPO="${CAPTAIN_REPO:-/home/kblack0610/dev/bnb/platform}"
MODEL="${CAPTAIN_MODEL:-claude-sonnet-4-6}"
INTERVAL="${CAPTAIN_INTERVAL:-12min}"
NTFY_URL="${NTFY_URL:-https://ntfy.kblab.me/agents}"
SHARED_HOOKS="$HOME/.dotfiles/.config/shared-hooks"
UNIT_DIR="$HOME/.config/systemd/user"
SERVICE="captain-watchdog.service"
TIMER="captain-watchdog.timer"

resolve_project() {
  if [ -f "$SHARED_HOOKS/project-name.sh" ]; then
    # shellcheck disable=SC1091
    . "$SHARED_HOOKS/project-name.sh"
    resolve_project_name "$REPO"
  else
    basename "$REPO"
  fi
}

# Newest sprint-*.md with a non-terminal row (queued|in-progress|pr-open).
# Prints the file path, or nothing if no active sprint.
active_blackboard() {
  local project plandir f
  project="$(resolve_project)"
  plandir="$HOME/.agent/plans/$project"
  [ -d "$plandir" ] || return 0
  # newest first
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    if grep -Eq '^\|[^|]*\|[^|]*\|.*\b(queued|in-progress|pr-open)\b' "$f"; then
      echo "$f"
      return 0
    fi
  done < <(ls -1t "$plandir"/sprint-*.md 2>/dev/null)
  return 0
}

cmd_run() {
  local bb
  bb="$(active_blackboard)"
  if [ -z "$bb" ]; then
    echo "captain-watchdog: no active sprint — disarming."
    cmd_disarm || true
    exit 0
  fi
  echo "captain-watchdog: active sprint $bb — running observe-only watch pass."
  cd "$REPO" 2>/dev/null || { echo "captain-watchdog: repo $REPO missing" >&2; exit 0; }
  # Observe-only pass. --dangerously-skip-permissions because watch never mutates
  # and a headless run must not hang on a permission prompt. Bounded by --max-turns.
  claude -p "/captain watch" \
    --model "$MODEL" \
    --dangerously-skip-permissions \
    --max-turns 30 \
    2>&1 | tail -40 || true
}

cmd_arm() {
  mkdir -p "$UNIT_DIR"
  local self
  self="$(readlink -f "$0")"
  cat >"$UNIT_DIR/$SERVICE" <<EOF
[Unit]
Description=Captain watchdog — observe-only sprint watch pass

[Service]
Type=oneshot
Environment=CAPTAIN_REPO=$REPO
Environment=CAPTAIN_MODEL=$MODEL
Environment=NTFY_URL=$NTFY_URL
ExecStart=/usr/bin/env bash -lc '$self run'
EOF
  cat >"$UNIT_DIR/$TIMER" <<EOF
[Unit]
Description=Captain watchdog timer (every $INTERVAL while a sprint is active)

[Timer]
OnBootSec=2min
OnUnitActiveSec=$INTERVAL
AccuracySec=1min
Persistent=false

[Install]
WantedBy=timers.target
EOF
  systemctl --user daemon-reload
  systemctl --user enable --now "$TIMER"
  echo "captain-watchdog: armed (every $INTERVAL, repo $REPO). Disarm with: captain-watchdog disarm"
}

cmd_disarm() {
  systemctl --user disable --now "$TIMER" 2>/dev/null || true
  rm -f "$UNIT_DIR/$SERVICE" "$UNIT_DIR/$TIMER"
  systemctl --user daemon-reload 2>/dev/null || true
  echo "captain-watchdog: disarmed."
}

cmd_status() {
  local bb
  bb="$(active_blackboard)"
  echo "repo:    $REPO"
  echo "project: $(resolve_project)"
  echo "sprint:  ${bb:-<none active>}"
  if systemctl --user is-active --quiet "$TIMER" 2>/dev/null; then
    echo "timer:   active"
    systemctl --user list-timers "$TIMER" --no-pager 2>/dev/null | sed -n '1,3p' || true
  else
    echo "timer:   inactive"
  fi
}

case "${1:-status}" in
  arm)    cmd_arm ;;
  disarm) cmd_disarm ;;
  run)    cmd_run ;;
  status) cmd_status ;;
  *) echo "usage: captain-watchdog {arm|disarm|run|status}" >&2; exit 2 ;;
esac
