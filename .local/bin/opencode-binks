#!/usr/bin/env bash
# opencode-binks — launch the opencode-binks fork.
#
# (Note: the `binks` command is the local-LLM Binks Agent, unrelated to this fork.)
#
# The fork keeps upstream's app name ("opencode") in packages/core/src/global.ts,
# so it transparently shares ~/.config/opencode and ~/.local/share/opencode with
# the stock pacman binary — no config duplication, and you can A/B the two.
#
# Resolution: prefer the locally-built fork binary; fall back to system opencode
# (with a one-line nudge) so the command always works even before the first build.
set -uo pipefail

FORK_DIR="${OPENCODE_BINKS_DIR:-$HOME/.local/src/opencode-binks}"
# Built artifact — must match BUILD_CMD's output path in the fork's .fork-sync.conf.
BIN="${OPENCODE_BINKS_BIN:-$FORK_DIR/dist/opencode-binks}"

if [ -x "$BIN" ]; then
  exec "$BIN" "$@"
fi

if command -v opencode >/dev/null 2>&1; then
  printf '\033[1;33mopencode-binks:\033[0m fork binary not built (%s) — running stock opencode.\n  Build it with: fork-sync %s\n' \
    "$BIN" "$FORK_DIR" >&2
  exec opencode "$@"
fi

echo "opencode-binks: neither the fork binary ($BIN) nor system 'opencode' is available." >&2
exit 127
