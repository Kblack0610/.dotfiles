#!/usr/bin/env bash
# agentctl-lab-sync — refresh the lab "Release & status feed" for active projects.
#
# The lab (~/.notes/lab/projects/current/{name}/) is the human↔agent project BUS:
# the slow, durable, multi-device layer between the fast ~/.agent runtime and the
# canonical in-repo CHANGELOG. This wrapper is the scheduled twin of the /lab-sync
# slash command (the way agentctl-dream pairs with /dream, agentctl-nightly-sync
# with /remember).
#
# Unlike dream/nightly-sync, this is DETERMINISTIC — no `claude --print`, no LLM,
# no network, zero token cost. The per-project feed is a mechanical mirror of git +
# ~/.agent, written by regen-lab-feed.sh into each summary.md's AUTO block (the human
# "## Status" / "## → For the agents" sections are never touched). Changelog PROSE on
# release stays with the LLM-driven release skills (placemyparents-release,
# bug-bash-wrapup) — see those.
#
# Cadence split (don't duplicate):
#   nightly-sync (23:00) — notes -> mem0
#   dream        (03:00) — agent corpus -> lessons/memory/mem0-queue
#   lab-sync     (weekly) — git + ~/.agent -> lab feed (this; slow, human-facing)
#
# Usage:
#   agentctl-lab-sync                 # refresh every active lab project
#   agentctl-lab-sync <lab-project>   # refresh one (e.g. placemyparents)

set -euo pipefail

REGEN="$HOME/.dotfiles/.claude/skills/lab-sync/regen-lab-feed.sh"
LOG="$HOME/.local/log/lab-sync.log"
INBOX="${AGENTCTL_INBOX:-$HOME/.local/state/agentctl/lab-sync}"
LAB_CURRENT="$HOME/.notes/lab/projects/current"
mkdir -p "$(dirname "$LOG")" "$INBOX"

ONE="${1:-}"

{
  printf '\n=== %s ===\n' "$(date -Is)"
  printf 'agent: lab-sync  mode: deterministic (regen-lab-feed)\n'
  printf 'inbox: %s\n\n' "$INBOX"

  if [ ! -x "$REGEN" ]; then
    printf '[lab-sync] ERROR: %s not found/executable\n' "$REGEN"
    printf '[%s] lab-sync: ERROR regen helper missing\n' "$(date -Is)" >> "$INBOX/activity.log"
    exit 1
  fi

  count=0
  if [ -n "$ONE" ]; then
    "$REGEN" "$ONE" && count=1 || true
  else
    if [ -d "$LAB_CURRENT" ]; then
      "$REGEN" --all || true
      count=$(find "$LAB_CURRENT" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
    else
      printf '[lab-sync] no lab projects dir at %s\n' "$LAB_CURRENT"
    fi
  fi

  # also refresh the cross-project index AUTO block (lab folders + git → index.md);
  # the hand-curated lanes that drive the daily note are never touched.
  IDX="$HOME/.dotfiles/.claude/skills/lab-sync/regen-project-index.sh"
  [ -x "$IDX" ] && "$IDX" >/dev/null || true

  printf '[%s] lab-sync: refreshed feed for %s project(s)%s\n' \
    "$(date -Is)" "$count" "${ONE:+ ($ONE)}" >> "$INBOX/activity.log"
  printf '\nlab-sync: refreshed %s project(s) + project index.\n' "$count"
  printf '=== exit: 0 ===\n'
} | tee -a "$LOG"
