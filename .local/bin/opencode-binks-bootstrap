#!/usr/bin/env bash
# opencode-binks-bootstrap — one-time setup of the opencode-binks fork.
#
# Creates the clean fork topology described in the plan:
#   upstream remote -> anomalyco/opencode
#   vendor branch   -> latest stable upstream tag (pristine, never hand-edited)
#   binks  branch   -> our patch series (seeded with fork infra + a BRANDING guide)
# and, when FORGEJO_TOKEN is set, creates the Forgejo-side repos:
#   <owner>/opencode-upstream  -> native PULL MIRROR of upstream (zero-maintenance)
#   <owner>/opencode-binks     -> our fork (origin); binks+vendor pushed up
#
# Idempotent: re-running skips anything already present. Local-only steps need no
# token; the Forgejo steps are skipped (with a notice) when FORGEJO_TOKEN is unset.
#
# Env:
#   FORK_DIR        (default ~/.local/src/opencode-binks)
#   UPSTREAM_URL    (default https://github.com/anomalyco/opencode)
#   FORGEJO_API     (default https://git.kblab.me/api/v1)
#   FORGEJO_OWNER   (default kblack0610)
#   FORGEJO_TOKEN   (optional; enables Forgejo repo + mirror creation)
set -uo pipefail

FORK_DIR="${FORK_DIR:-$HOME/.local/src/opencode-binks}"
UPSTREAM_URL="${UPSTREAM_URL:-https://github.com/anomalyco/opencode}"
FORGEJO_API="${FORGEJO_API:-https://git.kblab.me/api/v1}"
FORGEJO_OWNER="${FORGEJO_OWNER:-kblack0610}"
FORGEJO_HOST="$(printf '%s' "$FORGEJO_API" | sed -E 's#/api/v1/?$##')"

info() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31mxx\033[0m %s\n' "$*" >&2; exit 1; }

command -v git >/dev/null 2>&1 || die "git not found"

# ---- 1. local clone + remote ------------------------------------------------
if [ ! -d "$FORK_DIR/.git" ]; then
  info "cloning upstream into $FORK_DIR (this is large; once only)"
  git clone "$UPSTREAM_URL" "$FORK_DIR" || die "clone failed"
  git -C "$FORK_DIR" remote rename origin upstream
else
  info "reusing existing checkout at $FORK_DIR"
  git -C "$FORK_DIR" remote get-url upstream >/dev/null 2>&1 \
    || git -C "$FORK_DIR" remote add upstream "$UPSTREAM_URL"
fi
g() { git -C "$FORK_DIR" "$@"; }
g fetch --quiet --tags --prune upstream || die "fetch failed"

# ---- 2. resolve latest stable tag, seed vendor ------------------------------
latest_tag="$(g tag -l 'v[0-9]*' --sort=-v:refname | grep -Ev -e '-(rc|beta|alpha|pre)' | head -1)"
[ -n "$latest_tag" ] || die "could not resolve a stable upstream tag"
info "latest stable upstream tag: $latest_tag"

g rev-parse -q --verify refs/heads/vendor >/dev/null 2>&1 \
  || g branch vendor "$latest_tag"

# ---- 3. seed the binks patch branch with fork infra -------------------------
if ! g rev-parse -q --verify refs/heads/binks >/dev/null 2>&1; then
  info "seeding binks patch branch at $latest_tag"
  g checkout -q -b binks "$latest_tag"

  cat > "$FORK_DIR/.fork-sync.conf" <<'CONF'
# opencode-binks fork-sync config (consumed by ~/.local/bin/fork-sync).
UPSTREAM_REMOTE=upstream
UPSTREAM_URL=https://github.com/anomalyco/opencode
VENDOR_BRANCH=vendor
PATCH_BRANCH=binks
TAG_GLOB='v[0-9]*'
TAG_EXCLUDE='-(rc|beta|alpha|pre)'
# Build a single linux-amd64 binary from the rebased series. opencode is TS/Bun
# (verified on the dev branch: packages/opencode/script/build.ts). Adjust if the
# upstream build entrypoint moves on a future tag.
BUILD_CMD='bun install --frozen-lockfile && bun run --cwd packages/opencode script/build.ts && mkdir -p dist && cp packages/opencode/dist/opencode dist/opencode-binks'
# Single-writer model: fork-sync never pushes (local runs build the binary you run
# via `opencode-binks`). The Forgejo Action is the canonical publisher and pushes
# explicitly after a clean sync. Leave this empty.
PUSH_REMOTE=''
CONF

  mkdir -p "$FORK_DIR/.forgejo/workflows"
  cat > "$FORK_DIR/.forgejo/workflows/sync.yaml" <<'WF'
# Auto-sync: rebase the binks patch series onto each new upstream stable tag.
# Runs on the home-k3s Forgejo runner. On clean rebase it builds + force-pushes
# binks/vendor; on conflict the job FAILS (the seam where an LLM resolver / PR
# step plugs in later — see fork-sync exit code 2).
name: fork-sync
on:
  schedule:
    - cron: '0 7 * * *'   # daily 07:00 UTC
  workflow_dispatch: {}
jobs:
  sync:
    runs-on: docker
    container:
      image: oven/bun:1-debian
    steps:
      - name: install git + tooling
        run: apt-get update -qq && apt-get install -y -qq git curl >/dev/null
      - name: checkout fork (full history + tags)
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          ref: binks
      - name: configure git identity
        run: |
          git config user.name  "fork-sync[bot]"
          git config user.email "fork-sync@kblab.me"
      # Single-writer model: fork-sync rebases + builds (gate) but does NOT push;
      # CI publishes explicitly only on success. Conflict -> fork-sync exits 2 ->
      # this step fails -> push is skipped (the seam for a future LLM resolver / PR).
      - name: sync (rebase onto latest upstream tag + build gate)
        run: ./.forgejo/fork-sync .
      - name: publish (force-with-lease; only on a clean, built sync)
        env:
          TOKEN: ${{ secrets.FORGEJO_TOKEN }}
        run: |
          git remote set-url origin "https://x-access-token:${TOKEN}@git.kblab.me/${{ github.repository }}.git"
          git push origin vendor
          git push --force-with-lease origin binks
WF

  cat > "$FORK_DIR/BRANDING.md" <<'MD'
# opencode-binks — fork notes

This branch (`binks`) is a thin **patch series** replayed on top of an upstream
release tag by `fork-sync`. Keep it small and well-factored: one concern per
commit, so conflicts during a rebase arrive small and per-patch.

## Sync model
- `vendor` tracks the latest upstream stable tag (pristine — never edit it).
- `binks` = `vendor` + these patches. `fork-sync` rebases `binks` onto each new tag.
- Run `fork-sync` (or let the Forgejo Action do it) to advance. Conflicts stop the
  sync atomically (nothing is moved) and print how to resume.

## Where to put changes
- **Anything config can express** (models, agents, commands, keybinds, MCP, theme):
  do NOT patch source — put it in `~/.dotfiles/.config/opencode/`. It rides upstream
  releases for free.
- **Only what config cannot reach** becomes a patch here (editor/vim behaviour the
  keybind config can't express; visual rebranding).

## Branding patch points (verified present on the dev branch)
- `packages/tui/src/logo.ts` — ASCII wordmark / logo.
- `packages/opencode/package.json` — `name` / `bin` (binary command name).
- root `install` script — distribution name/URLs.
- **Do NOT change** `packages/core/src/global.ts` `const app = "opencode"` — it drives
  the XDG data/config dirs; keeping it shares `~/.config/opencode` with stock opencode.
MD

  # Vendor the fork-sync engine into the repo so the Forgejo Action is self-contained
  # (no external fetch). Local runs use ~/.local/bin/fork-sync; CI uses this copy.
  fs_src="$(command -v fork-sync || echo "$(dirname "$(readlink -f "$0")")/fork-sync")"
  if [ -r "$fs_src" ]; then
    cp "$fs_src" "$FORK_DIR/.forgejo/fork-sync"
    chmod +x "$FORK_DIR/.forgejo/fork-sync"
  else
    warn "could not locate fork-sync to vendor into .forgejo/ (CI step will fail until added)"
  fi

  g add .fork-sync.conf .forgejo/workflows/sync.yaml .forgejo/fork-sync BRANDING.md
  g commit -q -m "binks: fork-sync engine, config, CI workflow, and fork notes"
  info "binks seeded (1 infra commit; author your real patches on top)"
else
  info "binks branch already exists — leaving it"
fi
g checkout -q binks

# ---- 4. Forgejo-side repos (token-gated) ------------------------------------
if [ -z "${FORGEJO_TOKEN:-}" ]; then
  warn "FORGEJO_TOKEN unset — skipping Forgejo repo/mirror creation."
  warn "To finish the remote side, generate a token (Forgejo → Settings → Applications)"
  warn "and re-run:  FORGEJO_TOKEN=xxxxx opencode-binks-bootstrap"
  info "local fork is ready at $FORK_DIR (binks @ $latest_tag)"
  exit 0
fi

api() { curl -fsS -H "Authorization: token $FORGEJO_TOKEN" -H 'Content-Type: application/json' "$@"; }

# 4a. pull-mirror of upstream (native, auto-syncs)
if api "$FORGEJO_API/repos/$FORGEJO_OWNER/opencode-upstream" >/dev/null 2>&1; then
  info "mirror repo $FORGEJO_OWNER/opencode-upstream already exists"
else
  info "creating pull-mirror $FORGEJO_OWNER/opencode-upstream"
  api -X POST "$FORGEJO_API/repos/migrate" -d "{
    \"clone_addr\": \"$UPSTREAM_URL\",
    \"repo_name\": \"opencode-upstream\",
    \"repo_owner\": \"$FORGEJO_OWNER\",
    \"mirror\": true,
    \"mirror_interval\": \"30m0s\",
    \"private\": false
  }" >/dev/null && info "mirror created (interval 30m)" || warn "mirror creation failed"
fi

# 4b. the fork repo (origin)
if api "$FORGEJO_API/repos/$FORGEJO_OWNER/opencode-binks" >/dev/null 2>&1; then
  info "fork repo $FORGEJO_OWNER/opencode-binks already exists"
else
  info "creating fork repo $FORGEJO_OWNER/opencode-binks"
  api -X POST "$FORGEJO_API/user/repos" \
    -d '{"name":"opencode-binks","private":false,"auto_init":false}' >/dev/null \
    && info "fork repo created" || warn "fork repo creation failed"
fi

# 4c. wire origin + push branches
origin_url="$FORGEJO_HOST/$FORGEJO_OWNER/opencode-binks.git"
g remote get-url origin >/dev/null 2>&1 && g remote set-url origin "$origin_url" || g remote add origin "$origin_url"
info "pushing vendor + binks to origin"
g push -u "https://x-access-token:$FORGEJO_TOKEN@${origin_url#https://}" vendor binks \
  && info "pushed" || warn "push failed (check token scope)"

info "done. Remember to set the FORGEJO_TOKEN secret on $FORGEJO_OWNER/opencode-binks for the Action."
