#!/usr/bin/env bash
# notes-version-summary — prepend a short, plain-ASCII "## Summary" block to a frozen
# project version note (versions/ or changelog/ .md), generated by the LiteLLM gateway.
#
# WHY: the cockpit's `roll` freezes a project's working sheet verbatim (or mirrors long,
# hard-to-scan release prose). This adds a legible "where we're at / critical changes /
# what's next" blurb at the TOP of each frozen version so `o` (browse versions) is
# scannable at a glance. The original body is never touched — the block lives between
# `<!-- summary:auto -->` markers and is regenerable.
#
# The `notes` Rust CLI is deliberately HTTP-free; like comms triage, the LLM work lives
# here in an external script. Best-effort: on any network/LLM/config failure it exits
# non-zero WITHOUT writing, so a roll still succeeds.
#
# Usage:
#   notes-version-summary <profile> <project> <frozen-file.md>   # one version
#   notes-version-summary --backfill <profile> <project>         # every version in a project
#   notes-version-summary --backfill --all                       # every project, every profile
#   notes-version-summary --overview <profile> <project>         # write the "Next up" index into summary.md
#   notes-version-summary --overview --all                       # overview for every project
#   flags: --dry-run (print, write nothing)  --force (regenerate an existing block)
#          --rewrite (also rewrite the changelog BODY into clean legible prose, then summarize)
#
# Config (machine-local, not committed — see ~/.config/notes-cockpit/README.md):
#   ~/.config/notes-cockpit/llm.env   LLM_BASE_URL / LLM_MODEL [/ LLM_MODEL_FALLBACK] / key
#   ~/.config/notes-cockpit/repos     project=/abs/repo[:pathfilter]  (optional; git-log source)
# Primary model may be a paid route; keep a LOCAL fallback so a proxy outage degrades gracefully.
# Never route personal data through a proxy you have not vetted for it.

set -uo pipefail

CONF_DIR="${NOTES_COCKPIT_CONF:-$HOME/.config/notes-cockpit}"
REPOS_FILE="$CONF_DIR/repos"
LLM_ENV="$CONF_DIR/llm.env"

# Gateway comes from llm.env / the environment — never hardcode a host in this public repo.
# Model defaults to the fast local tier; base_url must be set (feature stays dormant otherwise).
# LLM_MODEL_FALLBACK (optional) is tried when the primary model errors — e.g. primary is a paid
# route and its upstream is down, fallback is a local model on the same gateway. Reasoning models
# need a big token budget (they spend tokens thinking before the answer), hence the high default.
LLM_BASE_URL="${LLM_BASE_URL:-}"
LLM_MODEL="${LLM_MODEL:-fast (Qwen3-4B)}"
LLM_MODEL_FALLBACK="${LLM_MODEL_FALLBACK:-}"
LLM_KEY_RBW="${LLM_KEY_RBW:-}"
LLM_MAXTOK="${LLM_MAXTOK:-3000}"           # summary calls
LLM_MAXTOK_REWRITE="${LLM_MAXTOK_REWRITE:-6000}"  # body rewrites (longer output)
# shellcheck source=/dev/null
[ -f "$LLM_ENV" ] && . "$LLM_ENV"

DRY_RUN=0
FORCE=0
BACKFILL=0
ALL=0
REWRITE=0
OVERVIEW=0

die() { echo "notes-version-summary: $*" >&2; exit 1; }

# ── config resolution ───────────────────────────────────────────────
# repo_of <project> -> sets REPO + PATHFILTER from the repos map (case-insensitive key).
repo_of() {
  REPO=""; PATHFILTER=""
  [ -f "$REPOS_FILE" ] || return 0
  local line val
  line="$(awk -F= -v k="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" \
    '!/^[[:space:]]*#/ { key=tolower($1); gsub(/[[:space:]]/,"",key); if (key==k){ sub(/^[^=]*=/,""); print; exit } }' \
    "$REPOS_FILE")"
  [ -z "$line" ] && return 0
  val="$(printf '%s' "$line" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
  REPO="${val%%:*}"
  case "$val" in *:*) PATHFILTER="${val#*:}" ;; esac
  # ~ expansion
  REPO="${REPO/#\~/$HOME}"
}

resolve_key() {
  [ -n "${LLM_API_KEY:-}" ] && { printf '%s' "$LLM_API_KEY"; return 0; }
  [ -n "$LLM_KEY_RBW" ] && command -v rbw >/dev/null 2>&1 && rbw get "$LLM_KEY_RBW" 2>/dev/null || true
}

# ── source gathering ────────────────────────────────────────────────
# note_body <file> -> the note's own content, minus frontmatter and any existing summary block.
note_body() {
  awk '
    /<!-- summary:auto -->/    { inblk=1; next }
    /<!-- \/summary:auto -->/  { inblk=0; next }
    inblk { next }
    NR==1 && $0=="---"         { infm=1; next }
    infm && $0=="---"          { infm=0; next }
    infm { next }
    { print }
  ' "$1"
}

# git_subjects <repo> <pathfilter> <prevtag> <tag> -> commit subjects for the version range.
# Uses <prevtag>..<tag> when both tags resolve, else recent commits touching the pathfilter.
git_subjects() {
  local repo="$1" pf="$2" prev="$3" tag="$4"
  [ -n "$repo" ] && [ -d "$repo/.git" ] || return 0
  local range=""
  if git -C "$repo" rev-parse -q --verify "refs/tags/$tag" >/dev/null 2>&1; then
    if [ -n "$prev" ] && git -C "$repo" rev-parse -q --verify "refs/tags/$prev" >/dev/null 2>&1; then
      range="$prev..$tag"
    else
      range="$tag"  # only the end tag known — cap the window below
    fi
  fi
  if [ -n "$range" ]; then
    if [ -n "$pf" ]; then
      git -C "$repo" log --no-merges --pretty=%s -n 60 "$range" -- "$pf" 2>/dev/null
    else
      git -C "$repo" log --no-merges --pretty=%s -n 60 "$range" 2>/dev/null
    fi
  fi
}

# extract_tickets <text> -> "VK-1, #490, #492 (+58 more)" (deterministic; empty when none).
# Tracker IDs (VK-/CU-/JIRA-style) are listed first, then PR/#refs; capped so the line stays
# scannable instead of dumping a wall of every PR number.
extract_tickets() {
  local cap=10 all n head
  all="$(printf '%s' "$1" \
    | grep -oE '\b[A-Z]{2,}-[0-9]+\b|\bCU-[a-z0-9]+\b|#[0-9]+' 2>/dev/null \
    | awk '!seen[$0]++' \
    | awk '/^#/{pr=pr" "$0; next}{print} END{if(pr){n=split(pr,a," ");for(i=1;i<=n;i++)print a[i]}}')"
  [ -n "$all" ] || return 0
  n="$(printf '%s\n' "$all" | grep -c .)"
  head="$(printf '%s\n' "$all" | head -n "$cap" | awk '{a=a sep $0; sep=", "} END{print a}')"
  if [ "$n" -gt "$cap" ]; then
    printf '%s (+%d more)' "$head" "$((n - cap))"
  else
    printf '%s' "$head"
  fi
}

# strip <think>...</think> spans — reasoning models (Qwen3 etc.) emit them and the gateway
# does not. Handles same-line, multi-line, and a trailing unclosed span (truncated thinking).
strip_think() {
  awk '
    inthink { if ($0 ~ /<\/think>/) { sub(/.*<\/think>/,""); inthink=0 } else next }
    {
      if ($0 ~ /<think>/) {
        if ($0 ~ /<\/think>/) { gsub(/<think>[^<]*<\/think>/,"") }
        else { sub(/<think>.*/,""); inthink=1 }
      }
      print
    }
  '
}

# ── ascii sanitize — kill the "AI-looking" tells + honor the plain-ASCII rule ──
sanitize() {
  sed -E \
    -e 's/\xE2\x80\x94/ - /g'  -e 's/\xE2\x80\x93/-/g' \
    -e "s/\xE2\x80\x98/'/g"    -e "s/\xE2\x80\x99/'/g" \
    -e 's/\xE2\x80\x9C/"/g'    -e 's/\xE2\x80\x9D/"/g' \
    -e 's/\xE2\x80\xA6/.../g'  -e 's/\xE2\x86\x92/->/g' -e 's/\xE2\x86\x90/<-/g' \
    -e 's/\xE2\x80\xA2/-/g'    -e 's/\xC2\xA0/ /g' \
    | { iconv -c -f UTF-8 -t ASCII 2>/dev/null || cat; }
}

# ── LLM call ────────────────────────────────────────────────────────
# _one_call <key> <model> <maxtok> <sys> <usr> -> message content on stdout; non-zero on
# transport error, a gateway/upstream error object, or empty content (so the caller falls back).
# Reads .message.content — reasoning models return their thinking in a separate .reasoning_content
# field the gateway keeps out of content, so no manual strip is needed for those.
_one_call() {
  local key="$1" model="$2" maxtok="$3" sys="$4" usr="$5" body resp content
  body="$(jq -n --arg m "$model" --arg s "$sys" --arg u "$usr" --argjson mt "$maxtok" \
    '{model:$m, temperature:0.2, max_tokens:$mt,
      messages:[{role:"system",content:$s},{role:"user",content:$u}]}')" || return 1
  resp="$(curl -sS --max-time 240 "$LLM_BASE_URL/chat/completions" \
    -H "Authorization: Bearer $key" -H 'Content-Type: application/json' \
    -d "$body" 2>/dev/null)" || return 1
  if printf '%s' "$resp" | jq -e '.error' >/dev/null 2>&1; then
    printf 'gateway error: %s\n' "$(printf '%s' "$resp" | jq -r '.error.message // .error')" >&2
    return 1
  fi
  content="$(printf '%s' "$resp" | jq -r '.choices[0].message.content // empty' 2>/dev/null)"
  [ -n "$content" ] || return 1
  printf '%s' "$content"
}

call_llm() { # $1=system $2=user [$3=max_tokens]  -> content; tries primary then fallback model
  local sys="$1" usr="$2" maxtok="${3:-$LLM_MAXTOK}" key out
  [ -n "$LLM_BASE_URL" ] || { echo "no gateway (set LLM_BASE_URL in ~/.config/notes-cockpit/llm.env)" >&2; return 1; }
  key="$(resolve_key)"
  [ -n "$key" ] || { echo "no gateway key (set LLM_KEY_RBW / LLM_API_KEY)" >&2; return 1; }
  if out="$(_one_call "$key" "$LLM_MODEL" "$maxtok" "$sys" "$usr")"; then
    printf '%s' "$out"; return 0
  fi
  if [ -n "$LLM_MODEL_FALLBACK" ]; then
    echo "primary '$LLM_MODEL' failed; falling back to '$LLM_MODEL_FALLBACK'" >&2
    if out="$(_one_call "$key" "$LLM_MODEL_FALLBACK" "$maxtok" "$sys" "$usr")"; then
      printf '%s' "$out"; return 0
    fi
  fi
  return 1
}

# ── block build + splice ────────────────────────────────────────────
build_block() { # $1=summary-body $2=tickets  -> the full marker-wrapped block
  local sum="$1" tickets="$2"
  printf '<!-- summary:auto -->\n'
  printf '%s\n' "$sum"
  [ -n "$tickets" ] && printf 'Tickets: %s\n' "$tickets"
  printf '<!-- /summary:auto -->\n'
}

# splice <file> <block> — replace any existing block, insert after frontmatter (or at top).
splice() {
  local file="$1" block="$2" tmp fm_end
  tmp="$(mktemp)" || return 1
  # strip a previous auto block
  awk '
    /<!-- summary:auto -->/   { inblk=1; next }
    /<!-- \/summary:auto -->/ { inblk=0; next }
    !inblk { print }
  ' "$file" > "$tmp"
  fm_end=""
  if [ "$(head -1 "$tmp")" = "---" ]; then
    fm_end="$(awk 'NR>1 && $0=="---"{print NR; exit}' "$tmp")"
  fi
  {
    if [ -n "$fm_end" ]; then
      sed -n "1,${fm_end}p" "$tmp"
      printf '\n%s\n' "$block"
      sed -n "$((fm_end + 1)),\$p" "$tmp" | sed '/./,$!d'   # drop leading blank lines
    else
      printf '%s\n\n' "$block"
      sed '/./,$!d' "$tmp"
    fi
  } > "$file"
  rm -f "$tmp"
}

# splice_nextup <file> <block> — replace the <!-- nextup:auto --> block in a project summary.md,
# inserting it just ABOVE the first "## " heading (i.e. above `## → For the agents`, under the
# title/markers), else after frontmatter, else at top. Leaves every other region untouched.
splice_nextup() {
  local file="$1" block="$2" tmp ins fm_end
  tmp="$(mktemp)" || return 1
  awk '
    /<!-- nextup:auto -->/   { inblk=1; next }
    /<!-- \/nextup:auto -->/ { inblk=0; next }
    !inblk { print }
  ' "$file" > "$tmp"
  ins="$(awk '/^## /{print NR; exit}' "$tmp")"
  if [ -n "$ins" ]; then
    {
      sed -n "1,$((ins - 1))p" "$tmp"
      printf '%s\n\n' "$block"
      sed -n "${ins},\$p" "$tmp"
    } > "$file"
  else
    fm_end=""
    [ "$(head -1 "$tmp")" = "---" ] && fm_end="$(awk 'NR>1 && $0=="---"{print NR; exit}' "$tmp")"
    {
      if [ -n "$fm_end" ]; then
        sed -n "1,${fm_end}p" "$tmp"; printf '\n%s\n' "$block"; sed -n "$((fm_end + 1)),\$p" "$tmp"
      else
        printf '%s\n\n' "$block"; cat "$tmp"
      fi
    } > "$file"
  fi
  rm -f "$tmp"
}

# frontmatter <file> -> the YAML frontmatter block (lines 1..closing ---, inclusive), or nothing.
frontmatter() {
  [ "$(head -1 "$1")" = "---" ] || return 0
  awk 'NR==1{print;next} {print} NR>1 && $0=="---"{exit}' "$1"
}

# write_full <file> <block> <newbody> — replace the whole note: frontmatter + summary block +
# the rewritten body. Used by --rewrite (splice() only swaps the block and keeps the old body).
write_full() {
  local file="$1" block="$2" newbody="$3" fm
  fm="$(frontmatter "$file")"
  {
    [ -n "$fm" ] && printf '%s\n' "$fm"
    printf '\n%s\n\n' "$block"
    printf '%s\n' "$newbody" | sed '/./,$!d'
  } > "$file"
}

# rewrite_body <project> <ver> <body> <subjects> -> a clean, legible changelog body on stdout.
# Preserves every real fact + ticket/PR ref; only reshapes the prose into scannable ASCII.
rewrite_body() {
  local project="$1" ver="$2" body="$3" subjects="$4" sys usr out
  sys='You rewrite a software release changelog entry into a clean, legible version.
Rules:
- Plain ASCII ONLY: no emoji, no em dashes (use a hyphen), no curly quotes, no arrows, no marketing words.
- Preserve EVERY real fact, feature name, file/flag name, and ticket/PR reference (e.g. #490) from the
  input. Never invent, never drop a change. If unsure, keep it.
- Organize under the standard headers that apply: ### Added, ### Changed, ### Fixed, ### Removed.
- One concise, concrete bullet per change; merge obvious duplicates; cut filler and hype. Keep it
  scannable - a human should grasp the release in a quick skim.
- Keep the top "## [x.y.z] - DATE" heading if the input has one.
Output ONLY the rewritten changelog markdown, nothing else.'
  usr="Project: $project   Version: $ver"$'\n\n'"Changelog to rewrite:"$'\n'"$body"
  [ -n "$subjects" ] && usr="$usr"$'\n\n'"Commit subjects for reference:"$'\n'"$subjects"
  out="$(call_llm "$sys" "$usr" "$LLM_MAXTOK_REWRITE")" || return 1
  printf '%s' "$out" | strip_think | sanitize | sed -e 's/[[:space:]]*$//'
}

# ── one version ─────────────────────────────────────────────────────
# all_versions <root> -> "vX.Y.Z<TAB>path" for every note under versions/ + changelog/, desc.
all_versions() {
  local root="$1" d
  for d in "$root/versions" "$root/changelog"; do
    [ -d "$d" ] && ls -1 "$d"/*.md 2>/dev/null
  done | awk -F/ 'NF{ b=$NF; sub(/\.md$/,"",b); print b"\t"$0 }' | sort -rV
}

prev_of() { # $1=version $2=versions-list("ver\tpath"…desc) -> the next-lower version tag
  awk -F'\t' -v v="$1" '$1==v{found=1; next} found{print $1; exit}' <<<"$2"
}

process_file() { # $1=profile $2=project $3=file $4=versions-list
  local profile="$1" project="$2" file="$3" vlist="$4"
  [ -f "$file" ] || { echo "no such file: $file" >&2; return 1; }
  # --rewrite always reprocesses; plain summarize skips a note that already has a block.
  if [ "$REWRITE" -eq 0 ] && [ "$FORCE" -eq 0 ] && grep -q '<!-- summary:auto -->' "$file"; then
    echo "skip (has summary): $(basename "$file")"; return 0
  fi
  local ver prev body subjects tickets sys usr sum block newbody=""
  ver="$(basename "$file" .md)"
  prev="$(prev_of "$ver" "$vlist")"
  body="$(note_body "$file")"
  repo_of "$project"
  subjects="$(git_subjects "$REPO" "$PATHFILTER" "$prev" "$ver")"
  tickets="$(extract_tickets "$body"$'\n'"$subjects")"

  # rewrite the body first (if asked), then summarize from the CLEAN version
  if [ "$REWRITE" -eq 1 ]; then
    newbody="$(rewrite_body "$project" "$ver" "$body" "$subjects")" \
      || { echo "rewrite failed: $project $ver" >&2; return 1; }
    [ -n "$newbody" ] || { echo "empty rewrite: $project $ver" >&2; return 1; }
    body="$newbody"
  fi

  sys='You write terse release summaries for a developer'\''s personal project tracker.
Plain ASCII ONLY: no emoji, no em dashes (use a hyphen), no curly quotes, no marketing words.
Be concrete and name real features. Output EXACTLY this and nothing else:
## Summary
<2 to 3 sentences: the current state, the most critical changes in this version, and what needs doing next>

Critical changes:
- <bullet, up to 5; omit this whole section if there is nothing notable>

Next: <one line of what is left or the next step>
Do NOT output a Tickets line.'
  usr="Project: $project   Version: $ver"$'\n\n'"Version notes / tasks:"$'\n'"${body:-(none)}"
  [ -n "$subjects" ] && usr="$usr"$'\n\n'"Commits in this version:"$'\n'"$subjects"

  sum="$(call_llm "$sys" "$usr")" || return 1
  sum="$(printf '%s' "$sum" | strip_think | sanitize | sed -e 's/[[:space:]]*$//' -e '/./,$!d')"
  [ -n "$sum" ] || { echo "empty summary from gateway (model may have truncated inside <think>)" >&2; return 1; }
  # guarantee the header even if the model dropped it
  grep -q '^## Summary' <<<"$sum" || sum="## Summary"$'\n'"$sum"
  block="$(build_block "$sum" "$tickets")"

  if [ "$DRY_RUN" -eq 1 ]; then
    echo "=== $project $ver ($file) ==="
    printf '%s\n' "$block"
    if [ "$REWRITE" -eq 1 ]; then printf -- '--- rewritten body ---\n%s\n' "$newbody"; fi
    return 0
  fi
  if [ "$REWRITE" -eq 1 ]; then
    write_full "$file" "$block" "$newbody" && echo "rewrote+summarized: $project $ver" || return 1
  else
    splice "$file" "$block" && echo "summarized: $project $ver" || return 1
  fi
}

# root_of <profile> <project> -> the project's directory (via `notes projects`)
root_of() {
  local summary
  summary="$(notes --profile "$1" projects 2>/dev/null \
    | awk -F'\t' -v n="$2" 'tolower($1)==tolower(n){print $2; exit}')"
  [ -n "$summary" ] && dirname "$summary"
}

backfill_project() { # $1=profile $2=project
  local root vlist rc=0
  root="$(root_of "$1" "$2")" || return 1
  [ -n "$root" ] || { echo "no such project: $1/$2" >&2; return 1; }
  vlist="$(all_versions "$root")"
  [ -n "$vlist" ] || { echo "no versions for $1/$2"; return 0; }
  local ver path
  while IFS=$'\t' read -r ver path; do
    [ -n "$path" ] || continue
    process_file "$1" "$2" "$path" "$vlist" || rc=1
  done <<<"$vlist"
  return $rc
}

backfill_all() {
  local rc=0 prof name
  while IFS= read -r prof; do
    [ -n "$prof" ] || continue
    while IFS=$'\t' read -r name _; do
      [ -n "$name" ] || continue
      backfill_project "$prof" "$name" || rc=1
    done < <(notes --profile "$prof" projects 2>/dev/null)
  done < <(notes config --profiles 2>/dev/null)
  return $rc
}

# ── project overview (the "Now / Next" index in summary.md) ─────────
# latest_summaries <root> [n=3] -> the ## Summary block from each of the last n releases, newest first,
# version-labeled (compact - summaries, not full bodies). Feeds the "Now" narrative with the recent arc.
latest_summaries() {
  local root="$1" n="${2:-3}" ver path body out=""
  while IFS=$'\t' read -r ver path; do
    [ -n "$path" ] && [ -f "$path" ] || continue
    if grep -q '<!-- summary:auto -->' "$path"; then
      body="$(awk '/<!-- summary:auto -->/{s=1;next} /<!-- \/summary:auto -->/{s=0} s' "$path")"
    else
      body="$(note_body "$path")"
    fi
    out="$out== $ver =="$'\n'"$body"$'\n\n'
  done < <(all_versions "$root" | head -n "$n")
  printf '%s' "$out"
}

# sheet_text <root> -> the working sheet (README.md) body — the current plan, all waves + tasks.
sheet_text() {
  local f="$1/README.md"
  [ -f "$f" ] || return 0
  note_body "$f"
}

# generate_overview <profile> <project> — write the <!-- nextup:auto --> block into summary.md as a
# thorough "## Now" (where we are) + "## Next" (direction + [ ] tasks), from the last few release
# summaries + a dated git log + the full working sheet. One deepseek pass (local fallback), ASCII.
generate_overview() {
  local profile="$1" project="$2" root summary_md releases sheet recent sys usr sum block
  root="$(root_of "$profile" "$project")" || return 1
  [ -n "$root" ] || { echo "no such project: $profile/$project" >&2; return 1; }
  summary_md="$root/summary.md"
  [ -f "$summary_md" ] || { echo "no summary.md for $profile/$project" >&2; return 1; }
  releases="$(latest_summaries "$root" 3)"
  sheet="$(sheet_text "$root")"
  repo_of "$project"; recent=""
  if [ -n "$REPO" ] && [ -d "$REPO/.git" ]; then
    if [ -n "$PATHFILTER" ]; then
      recent="$(git -C "$REPO" log --no-merges --date=short --pretty=format:'%ad %s' -n 40 -- "$PATHFILTER" 2>/dev/null)"
    else
      recent="$(git -C "$REPO" log --no-merges --date=short --pretty=format:'%ad %s' -n 40 2>/dev/null)"
    fi
  fi
  sys='You write a concise but THOROUGH "where we are / where we are going" index for a developer'\''s
project. Study ALL the inputs (recent releases, the dated commit history, the working sheet) before
writing. Plain ASCII ONLY: no emoji, no em dashes (use a hyphen), no curly quotes, no marketing words.
Name real features and reference ticket/PR refs (e.g. Vikunja 563, #490) when the inputs mention them.
Output EXACTLY these two sections and nothing else:

## Now
<2 to 4 sentences: the current version, what was recently shipped, the state and health of the app, and
what is actively in flight>

## Next
<1 to 2 sentences of direction, then 2 to 4 concrete next tasks as a checklist. Propose NEW next steps
(unfinished threads, verification, known gaps); do NOT repeat tasks already on the working sheet.>
- [ ] <task>
- [ ] <task>'
  usr="Project: $project"
  usr="$usr"$'\n\n'"Recent releases (newest first):"$'\n'"${releases:-(no releases yet)}"
  [ -n "$recent" ] && usr="$usr"$'\n\n'"Commit history (newest first):"$'\n'"$recent"
  usr="$usr"$'\n\n'"Working sheet (the current plan - do NOT repeat these as next tasks):"$'\n'"${sheet:-(empty)}"

  sum="$(call_llm "$sys" "$usr")" || { echo "overview failed: $profile/$project" >&2; return 1; }
  sum="$(printf '%s' "$sum" | strip_think | sanitize | sed -e 's/[[:space:]]*$//' -e '/./,$!d')"
  [ -n "$sum" ] || { echo "empty overview: $profile/$project" >&2; return 1; }
  grep -q '^## Now' <<<"$sum" || sum="## Now"$'\n'"$sum"
  block="<!-- nextup:auto -->"$'\n'"$sum"$'\n'"<!-- /nextup:auto -->"

  if [ "$DRY_RUN" -eq 1 ]; then
    echo "=== overview: $profile/$project ($summary_md) ==="
    printf '%s\n' "$block"
    return 0
  fi
  splice_nextup "$summary_md" "$block" && echo "overview: $profile/$project" || return 1
}

overview_all() {
  local rc=0 prof name
  while IFS= read -r prof; do
    [ -n "$prof" ] || continue
    while IFS=$'\t' read -r name _; do
      [ -n "$name" ] || continue
      generate_overview "$prof" "$name" || rc=1
    done < <(notes --profile "$prof" projects 2>/dev/null)
  done < <(notes config --profiles 2>/dev/null)
  return $rc
}

# ── args ────────────────────────────────────────────────────────────
command -v jq >/dev/null 2>&1 || die "jq not found on PATH"
command -v curl >/dev/null 2>&1 || die "curl not found on PATH"
command -v notes >/dev/null 2>&1 || die "notes CLI not found"

POS=()
for a in "$@"; do
  case "$a" in
    --dry-run) DRY_RUN=1 ;;
    --force)   FORCE=1 ;;
    --backfill) BACKFILL=1 ;;
    --all)     ALL=1 ;;
    --rewrite) REWRITE=1 ;;
    --overview) OVERVIEW=1 ;;
    -h|--help) sed -n '2,20p' "$0"; exit 0 ;;
    -*)        die "unknown flag: $a" ;;
    *)         POS+=("$a") ;;
  esac
done

if [ "$OVERVIEW" -eq 1 ]; then
  if [ "$ALL" -eq 1 ]; then
    overview_all
  else
    [ ${#POS[@]} -ge 2 ] || die "usage: --overview <profile> <project>   (or --overview --all)"
    generate_overview "${POS[0]}" "${POS[1]}"
  fi
  exit $?
fi

if [ "$BACKFILL" -eq 1 ]; then
  if [ "$ALL" -eq 1 ]; then
    backfill_all
  else
    [ ${#POS[@]} -ge 2 ] || die "usage: --backfill <profile> <project>   (or --backfill --all)"
    backfill_project "${POS[0]}" "${POS[1]}"
  fi
  exit $?
fi

[ ${#POS[@]} -ge 3 ] || die "usage: notes-version-summary <profile> <project> <file.md>"
root="$(root_of "${POS[0]}" "${POS[1]}")"
vlist="$(all_versions "${root:-$(dirname "${POS[2]}")/..}")"
[ -n "$vlist" ] || vlist="$(all_versions "$(dirname "${POS[2]}")/..")"
process_file "${POS[0]}" "${POS[1]}" "${POS[2]}" "$vlist"
