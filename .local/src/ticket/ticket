#!/usr/bin/env bash
# ticket — system-agnostic ticket CLI for the kb workflow.
#
# Speaks an abstract tracker contract so the kb pipeline never hard-codes a
# provider. Backends (vikunja|jira|clickup|linear|notion) live in backends/ and
# are selected per-repo via project-map.json `trackers`.
#
# Usage:
#   ticket [--dry-run] system
#   ticket [--dry-run] resolve-epic <shorthand>
#   ticket [--dry-run] claim <id>
#   ticket [--dry-run] create <epic> <title> [--labels=a,b,...]
#   ticket [--dry-run] done <id>
#   ticket [--dry-run] pr-line <id>
#
# Contract: docs/tracker-contract.md (in ~/.dotfiles/.claude/docs/).
# Each verb that mutates returns the PR-body line on stdout (the backend owns
# its format; the vikunja backend emits the legacy `Vikunja: <id>` for CI
# compatibility). `resolve-epic` returns a bare epic id. `system` returns the
# active backend name.

set -euo pipefail

HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
. "$HERE/lib/common.sh"
# shellcheck source=lib/config.sh
. "$HERE/lib/config.sh"

usage() { sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'; exit 64; }

# --- parse global flags -------------------------------------------------------
DRY_RUN=0
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) usage ;;
    *) die "unknown flag '$1'" ;;
  esac
done
export DRY_RUN

VERB="${1:-}"; [[ -n "$VERB" ]] || usage
shift || true

# --- repo-local override ------------------------------------------------------
# A repo can fully own its ticketing by shipping an executable scripts/ticket.sh
# implementing this same verb contract. If present, defer to it entirely.
_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
if [[ -x "$_root/scripts/ticket.sh" ]]; then
  exec "$_root/scripts/ticket.sh" "$VERB" "$@"
fi

# --- resolve backend ----------------------------------------------------------
load_tracker_config   # sets TICKET_SYSTEM + TICKET_CFG (or dies)

BACKEND="$HERE/backends/$TICKET_SYSTEM.sh"
[[ -f "$BACKEND" ]] || die "no backend for system '$TICKET_SYSTEM' (expected $BACKEND)"
# shellcheck source=/dev/null
. "$BACKEND"

# --- dispatch -----------------------------------------------------------------
case "$VERB" in
  system)       echo "$TICKET_SYSTEM" ;;
  resolve-epic) tb_resolve_epic "$@" ;;
  claim)        tb_claim "$@" ;;
  create)       tb_create "$@" ;;
  done)         tb_done "$@" ;;
  pr-line)      tb_pr_line "$@" ;;
  *) die "unknown verb '$VERB' (system|resolve-epic|claim|create|done|pr-line)" ;;
esac
