#!/usr/bin/env bash
# Automatic day/night theme selection
# Called by systemd timers or manually

DAY_THEME="jackie-brown"
NIGHT_THEME="tokyonight"
DAY_START=7    # 07:00
NIGHT_START=19 # 19:00

HOUR=$(date +%-H)
if (( HOUR >= DAY_START && HOUR < NIGHT_START )); then
    THEME="$DAY_THEME"
else
    THEME="$NIGHT_THEME"
fi

# Skip if already on the correct theme
CURRENT=$(cat ~/.config/theme/current 2>/dev/null || echo "")
if [[ "$CURRENT" == "$THEME" ]]; then
    echo "Already on $THEME, skipping"
    exit 0
fi

exec theme-switch "$THEME"
